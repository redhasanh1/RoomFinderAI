<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_secondary</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorSecondaryVariant">@color/accent_light</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_card</item>
        <item name="colorError">@color/colorError</item>
        
        <!-- Typography and icon colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnError">@color/white</item>
        
        <!-- System UI -->
        <item name="android:statusBarColor">@color/purple_primary</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>
    
    <!-- Marketplace specific styles -->
    <style name="MarketplaceTheme" parent="AppTheme">
        <item name="bottomNavigationStyle">@style/Widget.Marketplace.BottomNavigationView</item>
    </style>
    
    <!-- Bottom Navigation Style -->
    <style name="Widget.Marketplace.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/nav_selector</item>
        <item name="itemTextColor">@color/nav_selector</item>
        <item name="android:background">@color/nav_background</item>
        <item name="elevation">8dp</item>
    </style>
    
    <!-- Glass Card Style -->
    <style name="Widget.Marketplace.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_border</item>
    </style>
    
    <!-- Search Bar Style -->
    <style name="Widget.Marketplace.SearchBar" parent="">
        <item name="android:background">@drawable/search_background</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColorHint">@color/search_hint</item>
        <item name="android:textColor">@color/search_text</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.Marketplace.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/button_primary</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">16dp</item>
    </style>
    
    <style name="Widget.Marketplace.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/button_outline</item>
        <item name="android:textColor">@color/button_outline</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>