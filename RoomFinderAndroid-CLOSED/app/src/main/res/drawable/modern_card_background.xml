<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Shadow layer -->
    <item android:left="2dp" android:right="2dp" android:top="4dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/enhanced_shadow" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- Main card background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/enhanced_surface" />
            <corners android:radius="16dp" />
            <stroke 
                android:width="1dp" 
                android:color="@color/enhanced_border_light" />
        </shape>
    </item>
    
    <!-- Subtle inner highlight -->
    <item android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="@color/white_80"
                android:centerColor="@android:color/transparent"
                android:endColor="@android:color/transparent" />
            <corners android:radius="15dp" />
        </shape>
    </item>
    
</layer-list>