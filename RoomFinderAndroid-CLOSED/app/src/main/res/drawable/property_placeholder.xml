<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Background Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/gradient_start_primary"
                android:endColor="@color/gradient_end_primary"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- Glass Overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_overlay" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- House Icon -->
    <item android:gravity="center">
        <vector
            android:width="80dp"
            android:height="80dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="@color/white"
                android:fillAlpha="0.9"
                android:pathData="M12,3L2,12h3v8h6v-6h2v6h6v-8h3L12,3zM12,7.69l4,3.64V18h-2v-6H10v6H8v-6.67L12,7.69z"/>
        </vector>
    </item>
    
</layer-list>