<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Enhanced Glow Effect -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:startColor="#30667EEA"
                android:centerColor="#15667EEA"
                android:endColor="#00667EEA" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    
    <!-- Main Background -->
    <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFFFFF"
                android:centerColor="#FDFDFF"
                android:endColor="#FAFCFF" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    
    <!-- Enhanced Glass Effect -->
    <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#30FFFFFF"
                android:centerColor="#20FFFFFF"
                android:endColor="#10FFFFFF" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    
    <!-- Focused Border -->
    <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="26dp" />
            <stroke 
                android:width="2dp" 
                android:color="#60667EEA" />
        </shape>
    </item>
    
</layer-list>