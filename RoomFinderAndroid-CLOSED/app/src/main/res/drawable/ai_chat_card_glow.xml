<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Enhanced Outer Glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:startColor="#40667EEA"
                android:centerColor="#25764BA2"
                android:endColor="#0000FFCC" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    
    <!-- Secondary Glow Ring -->
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="100dp"
                android:startColor="#50667EEA"
                android:centerColor="#30764BA2"
                android:endColor="#0000FFCC" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    
    <!-- Premium Glass Card -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#667EEA"
                android:centerColor="#6B7FEB"
                android:endColor="#764BA2" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Glass Surface Effect -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#50FFFFFF"
                android:centerColor="#30FFFFFF"
                android:endColor="#10FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Premium Border -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="20dp" />
            <stroke 
                android:width="2dp" 
                android:color="#70FFFFFF" />
        </shape>
    </item>
    
    <!-- Reflection Highlight -->
    <item android:top="14dp" android:bottom="50dp" android:left="14dp" android:right="50dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#60FFFFFF"
                android:centerColor="#30FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    
</layer-list>