<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@color/background_light">

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="start"
        android:layout_marginBottom="32dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Go back"
        android:tint="@color/text_primary" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify Your Email"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Description -->
    <TextView
        android:id="@+id/verificationDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="We've sent a 6-digit verification code to:"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Email Display -->
    <TextView
        android:id="@+id/verificationEmailText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="user@example.com"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="16dp" />

    <!-- Demo Mode Code Display -->
    <androidx.cardview.widget.CardView
        android:id="@+id/demoCodeCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/background_demo"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧪 DEMO MODE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/purple_primary"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your verification code is:"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/demoCodeDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="123456"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/purple_primary"
                android:gravity="center"
                android:letterSpacing="0.5"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_background"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/autoFillButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Auto Fill"
                    android:textSize="12sp"
                    android:textColor="@color/purple_primary"
                    android:background="@drawable/button_outline"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="16dp" />

                <Button
                    android:id="@+id/copyCodeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Copy Code"
                    android:textSize="12sp"
                    android:textColor="@color/purple_primary"
                    android:background="@drawable/button_outline"
                    android:paddingHorizontal="16dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap code to select or use buttons above (no email was sent in demo mode)"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Verification Code Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/verificationCodeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter 6-digit code"
            android:inputType="number"
            android:maxLength="6"
            android:textSize="20sp"
            android:textAlignment="center"
            android:letterSpacing="0.3" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Verify Button -->
    <Button
        android:id="@+id/verifyButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:text="Verify Email"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/button_primary"
        android:textColor="@android:color/white"
        android:elevation="4dp" />

    <!-- Resend Code Button -->
    <Button
        android:id="@+id/resendCodeButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Resend Code"
        android:textSize="14sp"
        android:textColor="@color/primary"
        android:background="@drawable/button_outline"
        android:layout_marginBottom="16dp" />

    <!-- Skip Verification Button (Demo Mode) -->
    <Button
        android:id="@+id/skipVerificationButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Skip Verification (Demo Mode)"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:background="@android:color/transparent"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- Help Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Didn't receive the code? Check your spam folder or click resend."
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="16dp" />

    <!-- Debug Info (Demo Mode) -->
    <TextView
        android:id="@+id/debugInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:background="@color/gray_100"
        android:padding="8dp" />

</LinearLayout>