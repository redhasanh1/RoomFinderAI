# Environment Variables for RoomFinderAI
# Copy this file to .env for local development
# For Railway deployment, set these in the Railway dashboard under Variables
# NEVER commit .env file to version control!

# ========================================
# CORE SERVICES (Set what you have)
# ========================================

# Supabase Configuration (REQUIRED for database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI Configuration (optional if using Groq)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-organization-id-here-optional
OPENAI_MODEL=gpt-3.5-turbo

# Groq — free-tier LLM fallback (https://console.groq.com)
# Works without OpenAI. Set AI_PROVIDER=groq to prefer Groq.
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
AI_PROVIDER=auto

# ========================================
# OPTIONAL SERVICES
# ========================================

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Google API (for maps/geocoding - restrict key by HTTP referrer in Google Cloud)
GOOGLE_API_KEY=your-google-api-key

# RentCast API (optional market data)
RENTCAST_KEY=your-rentcast-api-key

# Cloudflare Turnstile (optional bot protection)
TURNSTILE_SITE_KEY=your-turnstile-site-key

# Brevo Email Service (for email verification)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=RoomFinderAI
CONTACT_EMAIL=support@roomfinderai.com

# Azure Services (for ID verification)
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-document-key
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FACE_KEY=your-azure-face-api-key
AZURE_FACE_ENDPOINT=https://your-face-resource.cognitiveservices.azure.com/

# ========================================
# SERVER CONFIGURATION
# ========================================

# Server Port
PORT=3000

# Node Environment (development, production, test)
# Railway production: set NODE_ENV=production
NODE_ENV=development

# ========================================
# FEATURE FLAGS
# ========================================

# Enable demo mode (uses mock data when services unavailable)
# Railway production: set ENABLE_DEMO_MODE=false
ENABLE_DEMO_MODE=true

# Allow anonymous browsing without login
ENABLE_ANONYMOUS_BROWSING=true

# Feature toggles (automatically disabled if required services missing)
ENABLE_AI_FEATURES=true
ENABLE_PAYMENT_FEATURES=true
ENABLE_EMAIL_FEATURES=true
ENABLE_ID_VERIFICATION=true

# ========================================
# SECURITY (Generate random values for production)
# ========================================

# JWT Secret for token signing (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Session Secret (generate with: openssl rand -base64 32)  
SESSION_SECRET=your-session-secret-here

# Admin API key for protected maintenance routes (required in production)
ADMIN_KEY=generate-a-strong-random-admin-key