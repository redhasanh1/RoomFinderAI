{
  "appId": "com.roomfinderai.app",
  "appName": "RoomFinderAI",
  "webDir": "frontend",
  "bundledWebRuntime": false,
  "android": {
    "buildOptions": {
      "javaVersion": "17"
    },
    "webDir": "frontend"
  },
  "ios": {
    "contentInset": "automatic",
    "allowsLinkPreview": false,
    "limitsNavigationsToAppBoundDomains": false
  },
  "server": {
    "url": "https://roomfinder-ai-negotiator-production.up.railway.app",
    "allowNavigation": [
      "roomfinder-ai-negotiator-production.up.railway.app",
      "*.supabase.co",
      "api.openai.com",
      "*.stripe.com",
      "*.googleapis.com"
    ]
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    }
  }
}
