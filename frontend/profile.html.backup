            }

            // Setup success metrics tracking
            setupSuccessMetricsTracking();

            // Display user listings from Supabase
            await displayUserListings();

            // Display saved/bookmarked listings
            await displaySavedListings();

            // Make displayUserListings available globally for edit/delete functions
            window.displayUserListings = displayUserListings;

            async function displayUserListings() {
                const userListings = document.getElementById('userListings');
                
                if (!userListings) {
                    console.error('❌ userListings element not found');
                    return;
                }
                
                try {
                    let listings = [];
                    
                    // Check if Supabase is available
                    if (typeof window.supabase !== 'undefined' && window.supabase) {
                        try {
                            // Fetch user's listings from Supabase
                            const { data, error } = await window.supabase
                                .from('listings')
                                .select('*')
                                .eq('user_email', currentUser.email)
                                .order('created_at', { ascending: false });
                                
                            console.log('✅ Fetched listings from Supabase:', { data, error, userEmail: currentUser.email });

                            if (error) {
                                throw new Error(`Supabase error: ${error.message}`);
                            }
                            
                            listings = data || [];
                        } catch (supabaseError) {
                            console.log('📱 Supabase unavailable, checking localStorage:', supabaseError.message);
                            
                            // Fallback to localStorage - check both storage locations
                            const storageKey = `userListings_${currentUser.email}`;
                            const storedListings = JSON.parse(localStorage.getItem(storageKey)) || [];
                            
                            // Also check currentUser.listings for backward compatibility
                            const userListings = currentUser.listings || [];
                            
                            // Merge both sources and remove duplicates based on ID
                            const allListings = [...storedListings, ...userListings];
                            const uniqueListings = allListings.reduce((acc, listing) => {
                                if (!acc.find(l => l.id === listing.id)) {
                                    acc.push(listing);
                                }
                                return acc;
                            }, []);
                            
                            listings = uniqueListings;
                            console.log('📱 Loaded listings from localStorage:', listings);
                        }
                    } else {
                        console.log('📱 Supabase not loaded, using localStorage only');
                        
                        // Use localStorage only - check both storage locations
                        const storageKey = `userListings_${currentUser.email}`;
                        const storedListings = JSON.parse(localStorage.getItem(storageKey)) || [];
                        
                        // Also check currentUser.listings for backward compatibility
                        const userListings = currentUser.listings || [];
                        
                        // Merge both sources and remove duplicates based on ID
                        const allListings = [...storedListings, ...userListings];
                        const uniqueListings = allListings.reduce((acc, listing) => {
                            if (!acc.find(l => l.id === listing.id)) {
                                acc.push(listing);
                            }
                            return acc;
                        }, []);
                        
                        listings = uniqueListings;
                        console.log('📱 Loaded listings from localStorage:', listings);
                    }

                    if (!listings || listings.length === 0) {
                        userListings.innerHTML = `
                            <div class="text-center py-12">
                                <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                                </svg>
                                <p class="text-gray-500 text-lg">No listings yet</p>
                                <p class="text-gray-400 text-sm mt-2">Start renting out your property to earn extra income</p>
                                <a href="listings.html" class="inline-block mt-4 bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                                    Create Your First Listing
                                </a>
                            </div>
                        `;
                        return;
                    }

                    userListings.innerHTML = '';
                    listings.forEach(listing => {
                        const listingCard = document.createElement('div');
                        listingCard.className = 'listing-card bg-white p-6 rounded-xl shadow-xl';
                        
                        const mediaHtml = listing.media && listing.media.length > 0
                            ? `<div class="listing-media flex flex-wrap mt-4">${listing.media.map(file => 
                                file.type && file.type.startsWith('image/')
                                    ? `<img src="${file.url}" alt="${file.name}" class="w-32 h-32 object-cover rounded">`
                                    : file.type && file.type.startsWith('video/')
                                    ? `<video src="${file.url}" controls class="w-32 h-32 object-cover rounded"></video>`
                                    : `<img src="${file.url}" alt="${file.name}" class="w-32 h-32 object-cover rounded">`
                            ).join('')}</div>`
                            : '';
                        
                        listingCard.innerHTML = `
                            <div class="flex justify-between items-start mb-4">
                                <h3 class="text-xl font-semibold text-gray-800">${listing.title}</h3>
                                <div class="flex space-x-2">
                                    <button onclick="editListing('${listing.id}')" class="bg-gradient-to-r from-purple-600 to-blue-600 text-white px-4 py-2 rounded-lg hover:from-purple-700 hover:to-blue-700 transition-all duration-300 font-medium shadow-md hover:shadow-lg hover:transform hover:-translate-y-0.5">
                                        Edit
                                    </button>
                                    <button onclick="deleteListing('${listing.id}')" class="bg-gradient-to-r from-red-600 to-pink-600 text-white px-4 py-2 rounded-lg hover:from-red-700 hover:to-pink-700 transition-all duration-300 font-medium shadow-md hover:shadow-lg hover:transform hover:-translate-y-0.5">
                                        Delete
                                    </button>
                                </div>
                            </div>
                            <p class="text-gray-600">Price: $${listing.price ? listing.price.toLocaleString() : 'N/A'}/month</p>
                            <p class="text-gray-600">Location: ${listing.city || 'Not specified'}</p>
                            <p class="text-gray-600">Address: ${listing.street || 'Not specified'}</p>
                            <p class="text-gray-600">Postal Code: ${listing.postalCode || 'Not specified'}</p>
                            <p class="text-gray-600">Type: ${listing.house_type || 'Not specified'}</p>
                            <p class="text-gray-600">Bedrooms: ${listing.bedrooms || 'Not specified'}</p>
                            <p class="text-gray-600">Utilities: ${listing.utilities || 'Not specified'}</p>
                            <p class="text-gray-600 mt-2">${listing.description || 'No description provided'}</p>
                            <p class="text-gray-500 text-sm mt-2">Created: ${new Date(listing.created_at).toLocaleDateString()}</p>
                            ${mediaHtml}
                        `;
                        userListings.appendChild(listingCard);
                    });
                } catch (err) {
                    console.error('Error displaying listings:', err);
                    userListings.innerHTML = '<p class="text-red-600 text-center">Error loading listings.</p>';
                }
            }

            // Display saved/bookmarked listings
            async function displaySavedListings() {
                const savedListingsContainer = document.getElementById('savedListingsContainer');
                const savedListingsEmpty = document.getElementById('savedListingsEmpty');
                const savedListingsCount = document.getElementById('savedListingsCount');
                
                // Add null checks to prevent errors
                if (!savedListingsContainer || !savedListingsCount) {
                    console.error('❌ Required DOM elements not found for saved listings');
                    return;
                }
                
                try {
                    console.log('🔖 Loading saved listings for user:', currentUser.email);
                    
                    let savedListings = [];
                    
                    try {
                        // Try API first
                        const response = await fetch(`/api/favorites?userEmail=${encodeURIComponent(currentUser.email)}`);
                        
                        if (!response.ok) {
                            throw new Error(`API failed: ${response.status}`);
                        }
                        
                        savedListings = await response.json();
                        console.log('📋 Fetched saved listings via API:', savedListings);
                    } catch (apiError) {
                        console.log('📱 API unavailable, loading from localStorage:', apiError.message);
                        
                        // Fallback to localStorage
                        const storageKey = `savedListings_${currentUser.email}`;
                        const savedData = JSON.parse(localStorage.getItem(storageKey)) || [];
                        
                        console.log('📱 Raw savedData from localStorage:', savedData);
                        
                        // Handle both old format (just IDs) and new format (full objects)
                        savedListings = [];
                        for (const item of savedData) {
                            if (typeof item === 'string') {
                                // Old format - just an ID, need to fetch the full listing
                                console.log('🔄 Converting old format ID to listing object:', item);
                                let actualListing = null;
                                const listingId = item;
                            
                            // Try to find the listing in Supabase first
                            if (typeof supabase !== 'undefined' && supabase) {
                                try {
                                    const { data, error } = await supabase
                                        .from('listings')
                                        .select('*')
                                        .eq('id', listingId)
                                        .single();
                                    
                                    if (!error && data) {
                                        actualListing = data;
                                    }
                                } catch (supabaseError) {
                                    console.log('Could not fetch listing from Supabase:', listingId);
                                }
                            }
                            
                            // If not found in Supabase, check localStorage
                            if (!actualListing) {
                                // Check all user listings in localStorage
                                const users = JSON.parse(localStorage.getItem('users')) || [];
                                for (const user of users) {
                                    // Check userListings key
                                    const userListingsKey = `userListings_${user.email}`;
                                    const userListings = JSON.parse(localStorage.getItem(userListingsKey)) || [];
                                    const found = userListings.find(l => l.id === listingId);
                                    if (found) {
                                        actualListing = found;
                                        break;
                                    }
                                    
                                    // Check user.listings
                                    if (user.listings) {
                                        const found = user.listings.find(l => l.id === listingId);
                                        if (found) {
                                            actualListing = found;
                                            break;
                                        }
                                    }
                                }
                            }
                            
                                if (actualListing) {
                                    // Add favorited_at timestamp
                                    savedListings.push({
                                        ...actualListing,
                                        listing_id: actualListing.id,
                                        favorited_at: new Date().toISOString()
                                    });
                                } else {
                                    console.warn('Could not find listing data for:', listingId);
                                }
                            } else {
                                // New format - already a complete listing object
                                console.log('✅ Using new format listing object:', item.id);
                                savedListings.push(item);
                            }
                        }
                        
                        console.log('📋 Loaded saved listings via localStorage:', savedListings);
                    }
                    
                    // Update count
                    savedListingsCount.textContent = `${savedListings.length} saved`;
                    
                    if (!savedListings || savedListings.length === 0) {
                        if (savedListingsEmpty) {
                            savedListingsEmpty.style.display = 'block';
                        }
                        return;
                    }
                    
                    // Hide empty state and show listings
                    if (savedListingsEmpty) {
                        savedListingsEmpty.style.display = 'none';
                    }
                    
                    // Clear only the listing cards, preserve the empty state element
                    const listingCards = savedListingsContainer.querySelectorAll('.saved-listing-card');
                    console.log(`🧹 Clearing ${listingCards.length} existing listing cards`);
                    listingCards.forEach(card => card.remove());
                    
                    // Verify empty state element still exists
                    const emptyStateCheck = document.getElementById('savedListingsEmpty');
                    console.log(`🔍 Empty state element exists after clear:`, !!emptyStateCheck);
                    
                    savedListings.forEach(listing => {
                        const listingCard = document.createElement('div');
                        const cardClass = listing.isOffline 
                            ? 'saved-listing-card bg-blue-50 border border-blue-200 rounded-lg p-4 hover:shadow-md transition-shadow'
                            : 'saved-listing-card bg-gray-50 border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow';
                        listingCard.className = cardClass;
                        
                        // Get primary image
                        const primaryImage = listing.media && listing.media.length > 0 && listing.media[0].type?.startsWith('image/')
                            ? listing.media[0].url
                            : 'data:image/svg+xml;base64,';
                        
                        const favoriteDate = listing.favorited_at ? new Date(listing.favorited_at).toLocaleDateString() : 'Unknown';
                        
                        listingCard.innerHTML = `
                            <div class="flex gap-4">
                                <img src="${primaryImage}" alt="${listing.title}" class="w-20 h-20 object-cover rounded-lg flex-shrink-0" onerror="this.src='data:image/svg+xml;base64,'">
                                <div class="flex-grow min-w-0">
                                    <div class="flex justify-between items-start">
                                        <h3 class="font-semibold text-gray-900 text-lg truncate">${listing.title}</h3>
                                        <button onclick="removeSavedListing('${listing.id}')" class="text-red-500 hover:text-red-700 ml-2 flex-shrink-0" title="Remove from favorites">
                                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                                <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                            </svg>
                                        </button>
                                    </div>
                                    <p class="text-xl font-bold text-blue-600">${listing.isOffline ? listing.price : `$${listing.price?.toLocaleString() || 'N/A'}/mo`}</p>
                                    <p class="text-gray-600 text-sm">${listing.isOffline ? listing.location : `${listing.street || ''}, ${listing.city || ''}`}</p>
                                    <div class="flex items-center space-x-2 text-sm text-gray-500 mt-2">
                                        <span>${listing.bedrooms || 'N/A'} Bed</span>
                                        <span>•</span>
                                        <span>${listing.house_type || 'N/A'}</span>
                                    </div>
                                    <div class="flex space-x-2 mt-3">
                                        <button data-listing-id="${listing.id}" onclick="viewListingDetails(this.getAttribute('data-listing-id'))" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition text-sm font-medium">View Details</button>
                                    </div>
                                </div>
                            </div>
                        `;
                        
                        savedListingsContainer.appendChild(listingCard);
                    });
                    
                } catch (error) {
                    console.error('❌ Error loading saved listings:', error);
                    savedListingsEmpty.innerHTML = `
                        <div class="text-center py-12">
                            <svg class="w-16 h-16 mx-auto text-red-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                            </svg>
                            <p class="text-gray-500 text-lg">Error loading saved listings</p>
                            <p class="text-gray-400 text-sm mt-2">${error.message}</p>
                            <button onclick="displaySavedListings()" class="inline-block mt-4 bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors">Retry</button>
                        </div>
                    `;
                    savedListingsCount.textContent = 'Error';
                }
            }

            // Function to remove a saved listing
            window.removeSavedListing = async function(listingId) {
                try {
                    console.log('🗑️ Removing saved listing:', listingId);
                    
                    let success = false;
                    
                    try {
                        // Try API first
                        const response = await fetch(`/api/favorites/${listingId}?userEmail=${encodeURIComponent(currentUser.email)}`, {
                            method: 'DELETE'
                        });
                        
                        if (!response.ok) {
                            throw new Error(`API failed: ${response.status}`);
                        }
                        
                        success = true;
                        console.log('✅ Removed from favorites via API:', listingId);
                    } catch (apiError) {
                        console.log('📱 API unavailable, removing from localStorage:', apiError.message);
                        
                        // Fallback to localStorage
                        const storageKey = `savedListings_${currentUser.email}`;
                        let savedListings = JSON.parse(localStorage.getItem(storageKey)) || [];
                        // Handle both old format (just IDs) and new format (full objects)
                        savedListings = savedListings.filter(item => {
                            const itemId = typeof item === 'string' ? item : item.id;
                            return itemId !== listingId;
                        });
                        localStorage.setItem(storageKey, JSON.stringify(savedListings));
                        
                        success = true;
                        console.log('✅ Removed from favorites via localStorage:', listingId);
                    }
                    
                    if (!success) {
                        throw new Error('Failed to remove saved listing');
                    }
                    
                    // Show success message
                    const toast = document.createElement('div');
                    toast.className = 'fixed top-20 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg z-50';
                    toast.textContent = 'Removed from favorites';
                    document.body.appendChild(toast);
                    
                    setTimeout(() => {
                        if (toast.parentElement) {
                            toast.remove();
                        }
                    }, 3000);
                    
                    // Remove the card from UI immediately without re-fetching
                    console.log(`🗑️ Removing card for listing: ${listingId}`);
                    const cardElement = document.querySelector(`[onclick="removeSavedListing('${listingId}')"]`);
                    if (cardElement) {
                        const listingCard = cardElement.closest('.saved-listing-card');
                        if (listingCard) {
                            console.log('🎬 Starting remove animation...');
                            listingCard.style.transition = 'all 0.3s ease';
                            listingCard.style.opacity = '0';
                            listingCard.style.transform = 'translateX(-100%)';
                            setTimeout(() => {
                                console.log('🚮 Removing card from DOM...');
                                listingCard.remove();
                                
                                // Check if this was the last card
                                const remainingCards = savedListingsContainer.querySelectorAll('.saved-listing-card').length;
                                console.log(`🔍 Cards remaining after removal: ${remainingCards}`);
                                
                                updateSavedListingsCount();
                                
                                // Extra check to ensure empty state shows
                                if (remainingCards === 0) {
                                    console.log('🔄 No cards left, ensuring empty state is visible');
                                    const savedListingsEmpty = document.getElementById('savedListingsEmpty');
                                    if (savedListingsEmpty) {
                                        savedListingsEmpty.style.display = 'block';
                                        savedListingsEmpty.style.visibility = 'visible';
                                        console.log('✅ Forced empty state to show');
                                    }
                                }
                            }, 300);
                        } else {
                            console.log('❌ Could not find listing card element');
                        }
                    } else {
                        console.log('❌ Could not find card element to remove');
                    }
                    
                } catch (error) {
                    console.error('❌ Error removing saved listing:', error);
                    alert('Failed to remove listing from favorites. Please try again.');
                }
            };
            
            // Function to update saved listings count
            function updateSavedListingsCount() {
                const savedListingsContainer = document.getElementById('savedListingsContainer');
                const savedListingsCount = document.getElementById('savedListingsCount');
                const savedListingsEmpty = document.getElementById('savedListingsEmpty');
                
                console.log('🔢 Updating saved listings count...');
                
                if (!savedListingsContainer || !savedListingsCount) {
                    console.log('❌ Missing required DOM elements for count update');
                    return;
                }
                
                const remainingCards = savedListingsContainer.querySelectorAll('.saved-listing-card').length;
                console.log(`📊 Found ${remainingCards} remaining cards`);
                
                savedListingsCount.textContent = `${remainingCards} saved`;
                
                if (savedListingsEmpty) {
                    if (remainingCards === 0) {
                        console.log('📝 Showing empty state message');
                        savedListingsEmpty.style.display = 'block';
                    } else {
                        console.log('📝 Hiding empty state message');
                        savedListingsEmpty.style.display = 'none';
                    }
                } else {
                    console.log('❌ savedListingsEmpty element not found!');
                }
                
                console.log(`✅ Updated count to: ${remainingCards} saved`);
            }

            // Function to view listing details
            window.viewListing = function(listingId) {
                window.location.href = `listing_details.html?id=${listingId}`;
            };

            // Logout
            const logoutButton = document.getElementById('logoutButton');
            if (logoutButton) {
                logoutButton.addEventListener('click', () => {
                    
                    // Set a flag to indicate this is a legitimate logout request
                    sessionStorage.setItem('legitimateLogout', 'true');
                    
                    // Clear all user data including backups
                    const keysToRemove = [
                        'currentUser',
                        'currentUser_backup',
                        'currentUser_backup_2',
                        'currentUser_emergency',
                        'currentUser_backup_timestamp'
                        // Don't clear 'users' array - it contains all registered users data
                    ];
                    
                    // Try multiple methods to clear data
                    keysToRemove.forEach(key => {
                        try {
                            // Method 1: Use original function if available
                            if (window.ORIGINAL_REMOVE_ITEM) {
                                window.ORIGINAL_REMOVE_ITEM.call(localStorage, key);
                            }
                            // Method 2: Try direct removal
                            localStorage.removeItem(key);
                            // Method 3: Set to null
                            localStorage.setItem(key, null);
                        } catch (e) {
                            console.error('Error removing', key, e);
                        }
                    });
                    
                    // Try multiple redirect methods
                    setTimeout(() => {
                        // Method 1: Original location setter
                        if (window.ORIGINAL_LOCATION_HREF) {
                            try {
                                window.ORIGINAL_LOCATION_HREF.set.call(window.location, 'login.html');
                            } catch (e) {
                                console.error('Original href failed:', e);
                            }
                        }
                        
                        // Method 2: Direct assignment
                        try {
                            window.location = 'login.html';
                        } catch (e) {
                            console.error('Direct assignment failed:', e);
                        }
                        
                        // Method 3: Form submission
                        const form = document.createElement('form');
                        form.method = 'GET';
                        form.action = 'login.html';
                        document.body.appendChild(form);
                        form.submit();
                    }, 100); // Small delay to ensure storage operations complete
                });
            } else {
                console.error('Logout button not found!');
            }
        }

        // Success metrics tracking for user satisfaction and performance
        function setupSuccessMetricsTracking() {
            console.log('🎯 Setting up success metrics tracking');
            
            // Track user satisfaction after AI negotiations
            trackUserSatisfaction();
            
            // Track deal completion metrics
            trackDealCompletion();
            
            // Set up user feedback collection
            setupUserFeedbackCollection();
        }

        async function trackUserSatisfaction() {
            try {
                // Get recent AI negotiations from the last week
                const oneWeekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
                
                const { data: recentNegotiations, error } = await supabase
                    .from('ai_chats')
                    .select('*')
                    .eq('user_email', currentUser.email)
                    .gte('created_at', oneWeekAgo)
                    .contains('metadata', { dealClosed: true });

                if (error) {
                    console.error('Error fetching recent negotiations:', error);
                    return;
                }

                // Show satisfaction survey for unrated negotiations
                for (const negotiation of recentNegotiations || []) {
                    if (!negotiation.metadata?.userSatisfactionRated) {
                        await showSatisfactionSurvey(negotiation);
                    }
                }

            } catch (error) {
                console.error('Error tracking user satisfaction:', error);
            }
        }

        async function showSatisfactionSurvey(negotiation) {
            // Create a non-intrusive satisfaction survey
            const satisfactionModal = document.createElement('div');
            satisfactionModal.className = 'fixed bottom-4 right-4 bg-white p-6 rounded-xl shadow-xl border-l-4 border-blue-500 max-w-sm z-50';
            satisfactionModal.innerHTML = `
                <div class="flex justify-between items-start mb-4">
                    <h3 class="font-semibold text-gray-800">📊 Quick Feedback</h3>
                    <button onclick="this.parentElement.parentElement.remove()" class="text-gray-400 hover:text-gray-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
                <p class="text-sm text-gray-600 mb-4">How satisfied were you with your AI negotiation for "${negotiation.title}"?</p>
                <div class="flex space-x-2 mb-4">
                    <button onclick="submitSatisfactionRating('${negotiation.id}', 5, this.parentElement.parentElement.parentElement)" class="px-3 py-1 bg-green-500 text-white rounded text-sm hover:bg-green-600">😄 Great</button>
                    <button onclick="submitSatisfactionRating('${negotiation.id}', 4, this.parentElement.parentElement.parentElement)" class="px-3 py-1 bg-blue-500 text-white rounded text-sm hover:bg-blue-600">😊 Good</button>
                    <button onclick="submitSatisfactionRating('${negotiation.id}', 3, this.parentElement.parentElement.parentElement)" class="px-3 py-1 bg-yellow-500 text-white rounded text-sm hover:bg-yellow-600">😐 OK</button>
                    <button onclick="submitSatisfactionRating('${negotiation.id}', 2, this.parentElement.parentElement.parentElement)" class="px-3 py-1 bg-orange-500 text-white rounded text-sm hover:bg-orange-600">😕 Poor</button>
                </div>
                <button onclick="this.parentElement.remove()" class="text-xs text-gray-500 hover:text-gray-700">Skip for now</button>
            `;

            document.body.appendChild(satisfactionModal);

            // Auto-remove after 30 seconds if no interaction
            setTimeout(() => {
                if (satisfactionModal.parentElement) {
                    satisfactionModal.remove();
                }
            }, 30000);
        }

        // Submit satisfaction rating and track metrics
        window.submitSatisfactionRating = async function(negotiationId, rating, modalElement) {
            try {
                console.log(`📊 Submitting satisfaction rating: ${rating} for negotiation ${negotiationId}`);

                // Update the negotiation record with satisfaction rating
                const { error } = await supabase
                    .from('ai_chats')
                    .update({
                        metadata: {
                            ...negotiationId.metadata,
                            userSatisfactionRated: true,
                            userSatisfactionRating: rating,
                            satisfactionTimestamp: new Date().toISOString()
                        }
                    })
                    .eq('id', negotiationId);

                if (error) {
                    console.error('Error saving satisfaction rating:', error);
                } else {
                    console.log('✅ Satisfaction rating saved successfully');
                    
                    // Log success metric to analytics
                    await logSuccessMetric('user_satisfaction', {
                        negotiationId: negotiationId,
                        rating: rating,
                        timestamp: new Date().toISOString(),
                        userEmail: currentUser.email
                    });
                }

                // Show thank you message
                modalElement.innerHTML = `
                    <div class="text-center">
                        <div class="text-2xl mb-2">🙏</div>
                        <p class="text-sm text-gray-600">Thank you for your feedback!</p>
                    </div>
                `;

                // Remove modal after 2 seconds
                setTimeout(() => modalElement.remove(), 2000);

            } catch (error) {
                console.error('Error submitting satisfaction rating:', error);
            }
        };

        // Track deal completion metrics
        async function trackDealCompletion() {
            try {
                // Get user's completed negotiations
                const { data: completedDeals, error } = await supabase
                    .from('ai_chats')
                    .select('*')
                    .eq('user_email', currentUser.email)
                    .contains('metadata', { dealClosed: true });

                if (error) {
                    console.error('Error fetching completed deals:', error);
                    return;
                }

                // Calculate and log deal completion metrics
                const dealMetrics = {
                    totalDeals: completedDeals?.length || 0,
                    averageSavings: 0,
                    totalSavings: 0,
                    successRate: 0
                };

                if (completedDeals && completedDeals.length > 0) {
                    const savings = completedDeals.map(deal => deal.metadata?.savings || 0);
                    dealMetrics.totalSavings = savings.reduce((sum, saving) => sum + saving, 0);
                    dealMetrics.averageSavings = Math.round(dealMetrics.totalSavings / completedDeals.length);
                    
                    // Success rate calculation (deals closed vs total negotiations)
                    const { data: allNegotiations } = await supabase
                        .from('ai_chats')
                        .select('id')
                        .eq('user_email', currentUser.email)
                        .like('title', '%Negotiation%');

                    if (allNegotiations) {
                        dealMetrics.successRate = Math.round((completedDeals.length / allNegotiations.length) * 100);
                    }
                }

                // Log deal completion metrics
                await logSuccessMetric('deal_completion', dealMetrics);

                console.log('📈 Deal completion metrics:', dealMetrics);

            } catch (error) {
                console.error('Error tracking deal completion:', error);
            }
        }

        // Setup user feedback collection
        function setupUserFeedbackCollection() {
            // Feedback button is now in footer, no need to create it dynamically
        }

        // Show feedback form
        function showFeedbackForm() {
            const feedbackModal = document.createElement('div');
            feedbackModal.className = 'fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center';
            feedbackModal.innerHTML = `
                <div class="bg-white rounded-xl p-6 max-w-md w-full mx-4">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-semibold text-gray-800">📝 Your Feedback</h3>
                        <button onclick="this.parentElement.parentElement.parentElement.remove()" class="text-gray-400 hover:text-gray-600">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>
                    
                    <form id="feedbackForm" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Feedback Type</label>
                            <select name="feedbackType" class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                                <option value="ai_negotiation">AI Negotiation Experience</option>
                                <option value="user_interface">User Interface</option>
                                <option value="feature_request">Feature Request</option>
                                <option value="bug_report">Bug Report</option>
                                <option value="general">General Feedback</option>
                            </select>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Your Feedback</label>
                            <textarea name="feedbackContent" rows="4" class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" placeholder="Please share your thoughts, suggestions, or report any issues..."></textarea>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Rating (1-5)</label>
                            <div class="flex space-x-2">
                                <button type="button" onclick="setRating(1, this)" class="rating-btn px-3 py-1 border rounded hover:bg-gray-100" data-rating="1">1</button>
                                <button type="button" onclick="setRating(2, this)" class="rating-btn px-3 py-1 border rounded hover:bg-gray-100" data-rating="2">2</button>
                                <button type="button" onclick="setRating(3, this)" class="rating-btn px-3 py-1 border rounded hover:bg-gray-100" data-rating="3">3</button>
                                <button type="button" onclick="setRating(4, this)" class="rating-btn px-3 py-1 border rounded hover:bg-gray-100" data-rating="4">4</button>
                                <button type="button" onclick="setRating(5, this)" class="rating-btn px-3 py-1 border rounded hover:bg-gray-100" data-rating="5">5</button>
                            </div>
                            <input type="hidden" name="rating" id="selectedRating" value="5">
                        </div>
                        
                        <div class="flex space-x-3 pt-4">
                            <button type="submit" class="flex-1 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                                Submit Feedback
                            </button>
                            <button type="button" onclick="this.closest('.fixed').remove()" class="flex-1 bg-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-400 transition">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
            `;

            document.body.appendChild(feedbackModal);

            // Handle form submission
            document.getElementById('feedbackForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const formData = new FormData(e.target);
                const feedbackData = {
                    userEmail: currentUser.email,
                    feedbackType: formData.get('feedbackType'),
                    content: formData.get('feedbackContent'),
                    rating: parseInt(formData.get('rating')),
                    timestamp: new Date().toISOString(),
                    userAgent: navigator.userAgent,
                    url: window.location.href
                };

                try {
                    await logSuccessMetric('user_feedback', feedbackData);
                    
                    // Show success message
                    feedbackModal.innerHTML = `
                        <div class="bg-white rounded-xl p-6 max-w-md w-full mx-4 text-center">
                            <div class="text-4xl mb-4">🙏</div>
                            <h3 class="text-lg font-semibold text-gray-800 mb-2">Thank You!</h3>
                            <p class="text-gray-600">Your feedback helps us improve RoomFinderAI.</p>
                        </div>
                    `;
                    
                    setTimeout(() => feedbackModal.remove(), 3000);
                    
                } catch (error) {
                    console.error('Error submitting feedback:', error);
                    alert('Error submitting feedback. Please try again.');
                }
            });
        }

        // Set rating for feedback form
        window.setRating = function(rating, button) {
            // Clear previous selection
            document.querySelectorAll('.rating-btn').forEach(btn => {
                btn.classList.remove('bg-blue-500', 'text-white');
                btn.classList.add('hover:bg-gray-100');
            });
            
            // Highlight selected rating and all previous
            for (let i = 1; i <= rating; i++) {
                const btn = document.querySelector(`[data-rating="${i}"]`);
                if (btn) {
                    btn.classList.add('bg-blue-500', 'text-white');
                    btn.classList.remove('hover:bg-gray-100');
                }
            }
            
            document.getElementById('selectedRating').value = rating;
        };

        // Log success metrics to Supabase
        async function logSuccessMetric(metricType, data) {
            try {
                const metricData = {
                    user_email: currentUser.email,
                    conversation_data: JSON.stringify([{
                        role: 'system',
                        content: `Success metric: ${metricType}`,
                        data: data,
                        timestamp: new Date().toISOString()
                    }]),
                    title: `Success Metric: ${metricType}`,
                    metadata: {
                        metricType: metricType,
                        metricData: data,
                        timestamp: new Date().toISOString(),
                        source: 'success_tracking'
                    }
                };

                const { error } = await supabase
                    .from('ai_chats')
                    .insert(metricData);

                if (error) {
                    console.error('Error logging success metric:', error);
                } else {
                    console.log(`✅ Success metric logged: ${metricType}`);
                }

            } catch (error) {
                console.error('Error in logSuccessMetric:', error);
            }
        }

        // Edit listing function
        window.editListing = async function(listingId) {
            try {
                let listing = null;
                
                // Try to fetch from Supabase first
                if (typeof supabase !== 'undefined' && supabase) {
                    try {
                        const { data, error } = await supabase
                            .from('listings')
                            .select('*')
                            .eq('id', listingId)
                            .single();
                        
                        if (!error && data) {
                            listing = data;
                            console.log('Loaded listing from Supabase');
                        }
                    } catch (supabaseError) {
                        console.log('Supabase fetch failed, checking localStorage:', supabaseError);
                    }
                }
                
                // If not found in Supabase, check localStorage
                if (!listing) {
                    const currentUser = JSON.parse(localStorage.getItem('currentUser'));
                    const userListingsKey = `userListings_${currentUser.email}`;
                    const userListings = JSON.parse(localStorage.getItem(userListingsKey)) || [];
                    
                    // Also check currentUser.listings
                    const currentUserListings = currentUser.listings || [];
                    const allListings = [...userListings, ...currentUserListings];
                    
                    listing = allListings.find(l => l.id === listingId);
                    
                    if (listing) {
                        console.log('Loaded listing from localStorage');
                    }
                }
                
                if (!listing) {
                    console.error('Listing not found in Supabase or localStorage');
                    alert('Error loading listing details');
                    return;
                }

                // Create edit modal
                const editModal = document.createElement('div');
                editModal.className = 'fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4';
                editModal.innerHTML = `
                    <div class="bg-white rounded-xl p-6 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-2xl font-semibold text-gray-800">Edit Listing</h3>
                            <button onclick="this.closest('.fixed').remove()" class="text-gray-400 hover:text-gray-600">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                </svg>
                            </button>
                        </div>
                        
                        <form id="editListingForm" class="space-y-4">
                            <input type="hidden" id="editListingId" value="${listing.id}">
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                                <input type="text" id="editTitle" value="${listing.title || ''}" 
                                    class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Price ($/month)</label>
                                    <input type="number" id="editPrice" value="${listing.price || ''}" 
                                        class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                                </div>
                                
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Bedrooms</label>
                                    <input type="number" id="editBedrooms" value="${listing.bedrooms || ''}" 
                                        class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                                </div>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">City</label>
                                <input type="text" id="editCity" value="${listing.city || ''}" 
                                    class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Street Address</label>
                                <input type="text" id="editStreet" value="${listing.street || ''}" 
                                    class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Postal Code</label>
                                <input type="text" id="editPostalCode" value="${listing.postalCode || ''}" 
                                    class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">House Type</label>
                                <select id="editHouseType" class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                                    <option value="apartment" ${listing.house_type === 'apartment' ? 'selected' : ''}>Apartment</option>
                                    <option value="house" ${listing.house_type === 'house' ? 'selected' : ''}>House</option>
                                    <option value="condo" ${listing.house_type === 'condo' ? 'selected' : ''}>Condo</option>
                                    <option value="townhouse" ${listing.house_type === 'townhouse' ? 'selected' : ''}>Townhouse</option>
                                    <option value="studio" ${listing.house_type === 'studio' ? 'selected' : ''}>Studio</option>
                                </select>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Utilities</label>
                                <input type="text" id="editUtilities" value="${listing.utilities || ''}" 
                                    class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                                    placeholder="e.g., Included, Not included, Partially included">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                                <textarea id="editDescription" rows="4" 
                                    class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">${listing.description || ''}</textarea>
                            </div>
                            
                            <div class="flex space-x-3 pt-4">
                                <button type="submit" class="flex-1 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                                    Save Changes
                                </button>
                                <button type="button" onclick="this.closest('.fixed').remove()" 
                                    class="flex-1 bg-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-400 transition">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                `;

                document.body.appendChild(editModal);

                // Handle form submission
                document.getElementById('editListingForm').addEventListener('submit', async function(e) {
                    e.preventDefault();
                    
                    const updatedListing = {
                        title: document.getElementById('editTitle').value,
                        price: parseFloat(document.getElementById('editPrice').value),
                        bedrooms: parseInt(document.getElementById('editBedrooms').value),
                        city: document.getElementById('editCity').value,
                        street: document.getElementById('editStreet').value,
                        postalCode: document.getElementById('editPostalCode').value,
                        house_type: document.getElementById('editHouseType').value,
                        utilities: document.getElementById('editUtilities').value,
                        description: document.getElementById('editDescription').value,
                        updated_at: new Date().toISOString()
                    };

                    try {
                        // Get current user
                        const currentUser = JSON.parse(localStorage.getItem('currentUser'));
                        if (!currentUser || !currentUser.email) {
                            alert('Please log in to edit listings.');
                            return;
                        }
                        
                        let updateSuccess = false;
                        
                        // Try backend API update first for better synchronization
                        try {
                            const response = await fetch(`/api/listings/${listingId}`, {
                                method: 'PUT',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({
                                    title: updatedListing.title,
                                    price: updatedListing.price,
                                    city: updatedListing.city,
                                    street: updatedListing.street,
                                    postalCode: updatedListing.postalCode,
                                    houseType: updatedListing.house_type,
                                    bedrooms: updatedListing.bedrooms,
                                    utilities: updatedListing.utilities,
                                    description: updatedListing.description
                                })
                            });
                            
                            if (response.ok) {
                                const result = await response.json();
                                console.log('✅ Listing updated via backend API:', result);
                                updateSuccess = true;
                            }
                        } catch (apiError) {
                            console.log('Backend API update failed, trying Supabase:', apiError);
                        }
                        
                        // Try Supabase update if API failed
                        if (!updateSuccess && typeof supabase !== 'undefined' && supabase && !listingId.startsWith('local_')) {
                            try {
                                // First verify the user owns this listing
                                const { data: existingListing, error: fetchError } = await supabase
                                    .from('listings')
                                    .select('*')
                                    .eq('id', listingId)
                                    .single();
                                    
                                console.log('Existing listing check:', { 
                                    listingId, 
                                    existingListing, 
                                    fetchError, 
                                    currentUserEmail: currentUser.email 
                                });
                                    
                                if (!fetchError && existingListing) {
                                    if (existingListing.user_email !== currentUser.email) {
                                        alert(`You can only edit your own listings.`);
                                        return;
                                    }
                                    
                                    // Now update the listing
                                    console.log('About to update with:', {
                                        listingId,
                                        userEmail: currentUser.email,
                                        updatedListing
                                    });
                                    
                                    const { data, error } = await supabase
                                        .from('listings')
                                        .update(updatedListing)
                                        .eq('id', listingId)
                                        .eq('user_email', currentUser.email)
                                        .select();

                                    if (!error && data && data.length > 0) {
                                        updateSuccess = true;
                                        console.log('✅ Listing updated in Supabase');
                                        
                                        // Clean up localStorage to ensure global consistency
                                        const userListingsKey = `userListings_${currentUser.email}`;
                                        let userListings = JSON.parse(localStorage.getItem(userListingsKey)) || [];
                                        const listingIndex = userListings.findIndex(l => l.id === listingId);
                                        
                                        if (listingIndex !== -1) {
                                            // Remove the listing from localStorage since Supabase is now the source of truth
                                            userListings.splice(listingIndex, 1);
                                            localStorage.setItem(userListingsKey, JSON.stringify(userListings));
                                            console.log('🧹 Cleaned localStorage to ensure Supabase data takes precedence');
                                        }
                                        
                                        // Also clean from currentUser.listings
                                        if (currentUser.listings) {
                                            const userListingIndex = currentUser.listings.findIndex(l => l.id === listingId);
                                            if (userListingIndex !== -1) {
                                                currentUser.listings.splice(userListingIndex, 1);
                                                let users = JSON.parse(localStorage.getItem('users')) || [];
                                                users = users.map(u => u.email === currentUser.email ? currentUser : u);
                                                localStorage.setItem('users', JSON.stringify(users));
                                                localStorage.setItem('currentUser', JSON.stringify(currentUser));
                                                console.log('🧹 Also cleaned currentUser.listings');
                                            }
                                        }
                                    }
                                }
                            } catch (supabaseError) {
                                console.log('Supabase update failed, will use localStorage:', supabaseError);
                            }
                        }
                        
                        // If Supabase failed or listing is local, update in localStorage
                        if (!updateSuccess) {
                            console.log('📱 Updating listing in localStorage');
                            
                            // Update in userListings
                            const userListingsKey = `userListings_${currentUser.email}`;
                            let userListings = JSON.parse(localStorage.getItem(userListingsKey)) || [];
                            const listingIndex = userListings.findIndex(l => l.id === listingId);
                            
                            if (listingIndex !== -1) {
                                userListings[listingIndex] = {
                                    ...userListings[listingIndex],
                                    ...updatedListing
                                };
                                localStorage.setItem(userListingsKey, JSON.stringify(userListings));
                                updateSuccess = true;
                            }
                            
                            // Also update in currentUser.listings
                            if (currentUser.listings) {
                                const userListingIndex = currentUser.listings.findIndex(l => l.id === listingId);
                                if (userListingIndex !== -1) {
                                    currentUser.listings[userListingIndex] = {
                                        ...currentUser.listings[userListingIndex],
                                        ...updatedListing
                                    };
                                    
                                    // Update users array
                                    let users = JSON.parse(localStorage.getItem('users')) || [];
                                    users = users.map(u => u.email === currentUser.email ? currentUser : u);
                                    localStorage.setItem('users', JSON.stringify(users));
                                    localStorage.setItem('currentUser', JSON.stringify(currentUser));
                                    updateSuccess = true;
                                }
                            }
                        }
                        
                        if (updateSuccess) {
                            // Close modal first
                            editModal.remove();
                            
                            // Trigger storage event to notify other pages
                            window.dispatchEvent(new CustomEvent('listingUpdated', { 
                                detail: { listingId: listingId, action: 'update' } 
                            }));
                            
                            // Also trigger a storage update to notify other tabs/windows
                            // This will fire a storage event in other tabs
                            const triggerKey = 'listingUpdateTrigger';
                            const triggerValue = JSON.stringify({
                                listingId: listingId,
                                action: 'update',
                                timestamp: Date.now()
                            });
                            localStorage.setItem(triggerKey, triggerValue);
                            // Clean up the trigger after a short delay
                            setTimeout(() => localStorage.removeItem(triggerKey), 100);
                            
                            // Show success message and refresh the entire page
                            alert('Listing updated successfully!');
                            window.location.reload();
                        } else {
                            console.error('Update failed - listing not found');
                            alert('Update failed - listing may not exist or you may not have permission to edit it.');
                        }
                    } catch (err) {
                        console.error('Error updating listing:', err);
                        alert('Error updating listing. Please try again.');
                    }
                });

            } catch (error) {
                console.error('Error in editListing:', error);
                alert('Error loading listing details');
            }
        };

        // Delete listing function
        window.deleteListing = async function(listingId) {
            if (!confirm('Are you sure you want to delete this listing? This action cannot be undone.')) {
                return;
            }

            try {
                // Get current user
                const currentUser = JSON.parse(localStorage.getItem('currentUser'));
                if (!currentUser || !currentUser.email) {
                    alert('Please log in to delete listings.');
                    return;
                }
                
                console.log('🗑️ Attempting to delete listing:', { listingId, userEmail: currentUser.email });
                let deleteSuccess = false;
                
                // Try Supabase delete first
                if (typeof supabase !== 'undefined' && supabase && !listingId.startsWith('local_')) {
                    try {
                        // First verify the user owns this listing
                        const { data: existingListing, error: fetchError } = await supabase
                            .from('listings')
                            .select('user_email')
                            .eq('id', listingId)
                            .single();
                            
                        if (!fetchError && existingListing) {
                            if (existingListing.user_email !== currentUser.email) {
                                alert('You can only delete your own listings.');
                                return;
                            }
                            
                            const { error } = await supabase
                                .from('listings')
                                .delete()
                                .eq('id', listingId)
                                .eq('user_email', currentUser.email);

                            if (!error) {
                                deleteSuccess = true;
                                console.log('✅ Listing deleted from Supabase');
                                
                                // Also clean up localStorage to keep them in sync
                                const userListingsKey = `userListings_${currentUser.email}`;
                                let userListings = JSON.parse(localStorage.getItem(userListingsKey)) || [];
                                userListings = userListings.filter(l => l.id !== listingId);
                                localStorage.setItem(userListingsKey, JSON.stringify(userListings));
                                
                                // Also clean up currentUser.listings
                                if (currentUser.listings) {
                                    currentUser.listings = currentUser.listings.filter(l => l.id !== listingId);
                                    let users = JSON.parse(localStorage.getItem('users')) || [];
                                    users = users.map(u => u.email === currentUser.email ? currentUser : u);
                                    localStorage.setItem('users', JSON.stringify(users));
                                    localStorage.setItem('currentUser', JSON.stringify(currentUser));
                                }
                                console.log('✅ Also cleaned up localStorage');
                            }
                        }
                    } catch (supabaseError) {
                        console.log('Supabase delete failed, will use localStorage:', supabaseError);
                    }
                }
                
                // If Supabase failed or listing is local, delete from localStorage
                if (!deleteSuccess) {
                    console.log('📱 Deleting listing from localStorage');
                    
                    // Delete from userListings
                    const userListingsKey = `userListings_${currentUser.email}`;
                    let userListings = JSON.parse(localStorage.getItem(userListingsKey)) || [];
                    const originalLength = userListings.length;
                    userListings = userListings.filter(l => l.id !== listingId);
                    
                    if (userListings.length < originalLength) {
                        localStorage.setItem(userListingsKey, JSON.stringify(userListings));
                        deleteSuccess = true;
                    }
                    
                    // Also delete from currentUser.listings
                    if (currentUser.listings) {
                        const originalUserListingsLength = currentUser.listings.length;
                        currentUser.listings = currentUser.listings.filter(l => l.id !== listingId);
                        
                        if (currentUser.listings.length < originalUserListingsLength) {
                            // Update users array
                            let users = JSON.parse(localStorage.getItem('users')) || [];
                            users = users.map(u => u.email === currentUser.email ? currentUser : u);
                            localStorage.setItem('users', JSON.stringify(users));
                            localStorage.setItem('currentUser', JSON.stringify(currentUser));
                            deleteSuccess = true;
                        }
                    }
                }
                
                if (deleteSuccess) {
                    console.log('🎉 Delete operation successful, listing ID:', listingId);
                    
                    // Trigger storage event to notify other pages
                    window.dispatchEvent(new CustomEvent('listingUpdated', { 
                        detail: { listingId: listingId, action: 'delete' } 
                    }));
                    
                    // Show success message and refresh the entire page
