            });

            // Display AI chat history
            const chatHistory = document.getElementById('chatHistory');
            if (!currentUser.aiChats || currentUser.aiChats.length === 0) {
                chatHistory.innerHTML = '<p class="text-gray-600 text-center">No AI chats yet.</p>';
            } else {
