    <script>
        var gk_isXlsx = false;
        var gk_xlsxFileLookup = {};
        var gk_fileData = {};
        function filledCell(cell) {
            return cell !== '' && cell != null;
        }
        function loadFileData(filename) {
            if (gk_isXlsx && gk_xlsxFileLookup[filename]) {
                try {
                    var workbook = XLSX.read(gk_fileData[filename], { type: 'base64' });
                    var firstSheetName = workbook.SheetNames[0];
                    var worksheet = workbook.Sheets[firstSheetName];
                    var jsonData = XLSX.utils.sheet_to_json(worksheet, { header: 1, blankrows: false, defval: '' });
                    var filteredData = jsonData.filter(row => row.some(filledCell));
                    var headerRowIndex = filteredData.findIndex((row, index) =>
                        row.filter(filledCell).length >= filteredData[index + 1]?.filter(filledCell).length
                    );
                    if (headerRowIndex === -1 || headerRowIndex > 25) {
                        headerRowIndex = 0;
                    }
                    var csv = XLSX.utils.aoa_to_sheet(filteredData.slice(headerRowIndex));
                    csv = XLSX.utils.sheet_to_csv(csv, { header: 1 });
                    return csv;
                } catch (e) {
                    console.error(e);
                    return "";
                }
            }
            return gk_fileData[filename] || "";
        }

        // Initialize configuration variables
        let configData;
        let supabase;
        let profileInitialized = false; // Flag to prevent double initialization

        // Try to initialize profile directly first (for local storage functionality)
        document.addEventListener('DOMContentLoaded', () => {
            // Initialize basic profile functionality without Supabase
            if (!profileInitialized) {
                initializeProfile().catch(err => {
                    console.error('Profile initialization error:', err);
                });
            }
        });

        // Load configuration from Railway API and initialize
        fetch('/api/config')
            .then(response => {
                if (!response.ok) {
                    throw new Error(`Configuration API error: ${response.status} ${response.statusText}`);
                }
                return response.json();
            })
            .then(config => {
                // Validate required configuration
                const missingKeys = [];
                if (!config.SUPABASE_URL) missingKeys.push('SUPABASE_URL');
                if (!config.SUPABASE_ANON_KEY) missingKeys.push('SUPABASE_ANON_KEY');
                
                if (missingKeys.length > 0) {
                    throw new Error(`Missing required configuration: ${missingKeys.join(', ')}`);
                }

                configData = {
                    SUPABASE_URL: config.SUPABASE_URL,
                    SUPABASE_ANON_KEY: config.SUPABASE_ANON_KEY
                };

                console.log('✅ Configuration loaded successfully:', {
                    hasSupabaseURL: !!configData.SUPABASE_URL,
                    hasSupabaseKey: !!configData.SUPABASE_ANON_KEY
                });

                // Initialize Supabase
                try {
                    supabase = window.supabase.createClient(configData.SUPABASE_URL, configData.SUPABASE_ANON_KEY);
                    console.log('✅ Supabase client created successfully');
                    
                    // Initialize the profile page if not already done
                    if (!profileInitialized) {
                        initializeProfile();
                    }
                } catch (supabaseError) {
                    throw new Error(`Supabase initialization failed: ${supabaseError.message}`);
                }
            })
            .catch(error => {
                console.error('❌ Configuration failed:', error);
                document.body.innerHTML = `
                    <div style="padding: 2rem; text-align: center; color: red;">
                        <h2>⚠️ Configuration Error</h2>
                        <p><strong>Failed to load profile page:</strong> ${error.message}</p>
                        <p><em>This usually means the Railway environment variables are not properly set.</em></p>
                        <button onclick="location.reload()" style="margin-top: 10px; padding: 8px 16px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            🔄 Retry
                        </button>
                    </div>
                `;
            });

        async function initializeProfile() {
            // Prevent double initialization
            if (profileInitialized) {
                console.log('Profile already initialized, skipping...');
                return;
            }
            profileInitialized = true;
            
            const currentUserStr = localStorage.getItem('currentUser');
            
            if (!currentUserStr) {
                console.log('No current user found, redirecting to login');
                window.location.href = 'login.html';
                return;
            }
            
            let currentUser;
            try {
                currentUser = JSON.parse(currentUserStr);
            } catch (e) {
                console.error('Error parsing current user:', e);
                window.location.href = 'login.html';
                return;
            }

            console.log('✅ Profile initialization started for:', currentUser.email);

            // Update the profile UI
            updateProfileUI(currentUser);
            
            // Load user data
            await loadUserListings(currentUser);
            await loadUserChatHistory(currentUser);
            await loadSavedListings(currentUser);
            
            console.log('✅ Profile page loaded successfully');
        }

        function updateProfileUI(user) {
            // Update profile information
            document.getElementById('userName').textContent = 
                `${user.firstName || ''} ${user.lastName || ''}`.trim() || 'User Name';
            document.getElementById('userEmail').textContent = user.email || 'No email';
            document.getElementById('userPhone').textContent = user.phone || '+1 (555) 123-4567';

            // Update verification badge
            if (user.verified) {
                const badge = document.getElementById('verificationBadge');
                badge.className = 'verified-badge';
                badge.innerHTML = `
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    Verified
                `;
            }

            // Calculate profile completion
            let completion = 25; // Base
            if (user.email) completion += 25;
            if (user.phone) completion += 25;
            if (user.verified) completion += 25;
            
            document.getElementById('completionPercent').textContent = completion + '%';
            document.getElementById('progressFill').style.width = completion + '%';
        }

        async function loadUserListings(user) {
            try {
                const userListingsKey = `userListings_${user.email}`;
                const userListings = JSON.parse(localStorage.getItem(userListingsKey)) || [];
                
                console.log('🏠 Loading user listings:', {
                    key: userListingsKey,
                    count: userListings.length,
                    listings: userListings
                });
                
                document.getElementById('listingsCount').textContent = userListings.length;
                
                const container = document.getElementById('userListings');
                if (userListings.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-12">
                            <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                            </svg>
                            <h3 class="text-lg font-medium text-gray-900 mb-2">No listings yet</h3>
                            <p class="text-gray-500">Create your first listing to get started</p>
                            <a href="listings.html" class="inline-block mt-4 bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors">Create Listing</a>
                        </div>
                    `;
                } else {
                    container.innerHTML = userListings.map(listing => {
                        console.log('📝 Processing listing:', listing);
                        
                        // Create a more robust display with fallbacks
                        const title = listing.title || listing.name || 'Untitled Listing';
                        const price = listing.price || 0;
                        const location = [listing.street, listing.city].filter(x => x).join(', ') || 'No location';
                        const createdDate = listing.created_at ? new Date(listing.created_at).toLocaleDateString() : 'Unknown date';
                        const bedrooms = listing.bedrooms || '?';
                        const houseType = listing.house_type || listing.type || 'Property';
                        
                        return `
                        <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg mb-3">
                            <div class="flex-1">
                                <h4 class="font-semibold text-gray-900">${title}</h4>
                                <p class="text-sm text-gray-600">$${price.toLocaleString()}/month • ${location}</p>
                                <p class="text-xs text-gray-500">${bedrooms} bed ${houseType} • Created: ${createdDate}</p>
                            </div>
                            <div class="flex space-x-2">
                                <button onclick="editListing('${listing.id}')" class="text-blue-600 hover:text-blue-700 font-medium text-sm">Edit</button>
                                <button onclick="deleteListing('${listing.id}')" class="text-red-600 hover:text-red-700 font-medium text-sm">Delete</button>
                            </div>
                        </div>
                    `;
                    }).join('');
                }
            } catch (error) {
                console.error('Error loading user listings:', error);
            }
        }

        async function loadUserChatHistory(user) {
            try {
                const chatHistoryKey = `chatHistory_${user.email}`;
                const chatHistory = JSON.parse(localStorage.getItem(chatHistoryKey)) || [];
                
                const container = document.getElementById('chatHistory');
                if (chatHistory.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-12">
                            <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                            </svg>
                            <h3 class="text-lg font-medium text-gray-900 mb-2">No chat history</h3>
                            <p class="text-gray-500">Start chatting with our AI to see your history here</p>
                        </div>
                    `;
                } else {
                    container.innerHTML = chatHistory.slice(-5).map(chat => `
                        <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                            <div class="flex-1">
                                <h4 class="font-semibold text-gray-900">${chat.title || 'Chat Session'}</h4>
                                <p class="text-sm text-gray-600">${chat.preview || 'No preview available'}</p>
                                <p class="text-xs text-gray-500">${new Date(chat.timestamp || Date.now()).toLocaleDateString()}</p>
                            </div>
                            <button onclick="viewChat('${chat.id}')" class="text-blue-600 hover:text-blue-700 font-medium text-sm">View</button>
                        </div>
                    `).join('');
                }
            } catch (error) {
                console.error('Error loading chat history:', error);
            }
        }

