                                        <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                    </svg>
                                    Remove
                                </button>
                            </div>
                        </div>
                    `;
                    }).join('');
                }
            } catch (error) {
                console.error('Error loading saved listings:', error);
            }
        }

        // Verification modal functions
        function openVerificationModal() {
            document.getElementById('verificationModal').classList.remove('hidden');
            resetModal();
        }

        function closeVerificationModal() {
            document.getElementById('verificationModal').classList.add('hidden');
        }

        function resetModal() {
            document.getElementById('uploadSection').classList.remove('hidden');
            document.getElementById('loadingSection').classList.add('hidden');
            document.getElementById('successSection').classList.add('hidden');
        }

        function selectFile() {
            document.getElementById('idFileInput').click();
        }

        // Handle file upload
        document.getElementById('idFileInput')?.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                // Show loading
                document.getElementById('uploadSection').classList.add('hidden');
                document.getElementById('loadingSection').classList.remove('hidden');
                
                // Simulate upload process
                let progress = 0;
                const interval = setInterval(() => {
                    progress += 10;
                    document.getElementById('progressBar').style.width = progress + '%';
                    
                    if (progress >= 100) {
                        clearInterval(interval);
                        document.getElementById('progressText').textContent = 'Processing...';
                        
                        // Show success after 2 seconds
                        setTimeout(() => {
                            document.getElementById('loadingSection').classList.add('hidden');
                            document.getElementById('successSection').classList.remove('hidden');
                            
                            // Update verification status
                            const currentUser = JSON.parse(localStorage.getItem('currentUser')) || {};
                            currentUser.verified = true;
                            localStorage.setItem('currentUser', JSON.stringify(currentUser));
                            
                            // Update UI
                            updateProfileUI(currentUser);
                        }, 2000);
                    }
                }, 200);
            }
        });

        // Placeholder functions
        function editProfile() {
            alert('Edit profile functionality coming soon!');
        }

        function editListing(id) {
            alert('Edit listing functionality coming soon!');
        }

        function deleteListing(id) {
            if (confirm('Are you sure you want to delete this listing?')) {
                const currentUser = JSON.parse(localStorage.getItem('currentUser')) || {};
                const userListingsKey = `userListings_${currentUser.email}`;
                let userListings = JSON.parse(localStorage.getItem(userListingsKey)) || [];
                
                userListings = userListings.filter(l => l.id !== id);
                localStorage.setItem(userListingsKey, JSON.stringify(userListings));
                
                loadUserListings(currentUser);
            }
        }

        function viewChat(id) {
            alert('View chat functionality coming soon!');
        }

        function viewListing(id) {
            window.location.href = `listing-details.html?id=${id}`;
        }

        function unsaveListing(id) {
            const currentUser = JSON.parse(localStorage.getItem('currentUser')) || {};
            const savedListingsKey = `savedListings_${currentUser.email}`;
            let savedListingIds = JSON.parse(localStorage.getItem(savedListingsKey)) || [];
            
            console.log('🗑️ Removing saved listing:', {
                id: id,
                beforeRemoval: savedListingIds
            });
            
            // Remove the listing ID from the array
            savedListingIds = savedListingIds.filter(savedId => savedId !== id);
            localStorage.setItem(savedListingsKey, JSON.stringify(savedListingIds));
            
            console.log('✅ Updated saved listings:', savedListingIds);
            
            // Reload the saved listings
            loadSavedListings(currentUser);
        }

        function logout() {
            localStorage.removeItem('currentUser');
            window.location.href = 'login.html';
        }

