# RoomFinderAI Environment Variables
# Copy this file to .env and fill in your actual values

# Database
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Payment Processing
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# AI Services
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here
OPENAI_MODEL=gpt-3.5-turbo

# Azure Services (Optional)
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_key_here
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=your_azure_endpoint_here
AZURE_FACE_KEY=your_azure_face_key_here
AZURE_FACE_ENDPOINT=your_azure_face_endpoint_here

# Maps and Location
GOOGLE_API_KEY=your_google_maps_api_key_here

# Email Services
BREVO_API_KEY=your_brevo_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=production