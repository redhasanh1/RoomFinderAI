# Local Properties Template for RoomFinder Android App
# Copy this file to local.properties and add your actual API keys
# NEVER commit local.properties to version control!

# Android SDK location (auto-generated by Android Studio)
# sdk.dir=/path/to/your/android/sdk

# API Keys Configuration

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here
OPENAI_MODEL=gpt-3.5-turbo

# Azure Services
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=your_azure_document_intelligence_endpoint_here
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_document_intelligence_key_here
AZURE_FACE_ENDPOINT=your_azure_face_endpoint_here
AZURE_FACE_KEY=your_azure_face_key_here

# Email Service
BREVO_API_KEY=your_brevo_api_key_here

# Google Services
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here

# Real Estate API
RENTCAST_KEY=your_rentcast_key_here

# Payment Processing (Stripe)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Backend Services (Supabase)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Security (Cloudflare Turnstile)
TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here