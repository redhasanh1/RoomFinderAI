<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:gravity="start">

    <!-- AI Avatar -->
    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="6dp">
        
        <ImageView
            android:id="@+id/aiAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/glassmorphism_card"
            android:src="@drawable/ic_computer"
            android:padding="10dp"
            android:tint="@color/white"
            android:elevation="4dp"
            android:contentDescription="AI Assistant Avatar" />
            
        <View
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ai_chat_card_glow"
            android:alpha="0.4" />
        
    </FrameLayout>

    <!-- Property Card Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="40dp">

        <!-- Property Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/property_card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/property_card_border">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Property Title -->
                <TextView
                    android:id="@+id/propertyTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2 Bedroom Apartment"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Property Details -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <!-- Location -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_home"
                            android:tint="@color/icon_secondary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/propertyLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Downtown Toronto"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <!-- Price -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_money"
                            android:tint="@color/success"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/propertyPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$2,000/month"
                            android:textColor="@color/success"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Bedrooms & Bathrooms -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_bed"
                            android:tint="@color/icon_secondary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/propertyBedBath"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 bed, 1 bath"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <!-- Property Type -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_home"
                            android:tint="@color/icon_secondary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/propertyType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Apartment"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Contact Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/contactLandlordButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📱 Contact Landlord"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chat"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Message Metadata -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:35 PM"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>