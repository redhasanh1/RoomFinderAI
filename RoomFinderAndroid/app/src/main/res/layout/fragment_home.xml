<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/background">

                <!-- Hero Section with Gradient Background -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="@drawable/gradient_primary"
                    android:orientation="horizontal"
                    android:padding="24dp"
                    android:gravity="center_vertical">

                    <!-- Hero Image on Left -->
                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="20dp"
                        android:src="@drawable/house_model_hero"
                        android:scaleType="fitCenter"
                        android:alpha="0.9" />

                    <!-- Hero Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Find Your Perfect Home"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:elevation="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Discover amazing properties with AI-powered search"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:alpha="0.95"
                            android:elevation="2dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Search Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="-40dp">

                    <!-- Search Bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/search_bar_background"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:elevation="4dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_search"
                            android:tint="@color/gray_500" />

                        <EditText
                            android:id="@+id/searchInput"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:background="@null"
                            android:hint="Search for properties..."
                            android:textColorHint="@color/gray_500"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:inputType="text"
                            android:imeOptions="actionSearch" />

                        <ImageView
                            android:id="@+id/filterButton"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_settings"
                            android:tint="@color/gray_500"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp" />

                    </LinearLayout>

                    <!-- Filter Chips -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="4dp">

                            <TextView
                                android:id="@+id/chipAll"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="All"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:background="@drawable/filter_chip_background"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:layout_marginEnd="8dp"
                                android:clickable="true" />

                            <TextView
                                android:id="@+id/chipApartment"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Apartment"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:background="@drawable/filter_chip_background"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/chipHouse"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="House"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:background="@drawable/filter_chip_background"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/chipCondo"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Condo"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:background="@drawable/filter_chip_background"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginEnd="8dp" />

                        </LinearLayout>

                    </HorizontalScrollView>

                </LinearLayout>

                <!-- Listings Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Featured Properties"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View All"
                            android:textColor="@color/purple_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Listings RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- Loading Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="32dp">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/house_model_hero"
                android:alpha="0.5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="No Properties Found"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Try adjusting your search criteria"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

        </LinearLayout>

        <!-- Error State -->
        <LinearLayout
            android:id="@+id/errorLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="32dp">

            <TextView
                android:id="@+id/errorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Something went wrong"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/retryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Try Again"
                android:backgroundTint="@color/purple_primary"
                android:textColor="@color/white"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </FrameLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>