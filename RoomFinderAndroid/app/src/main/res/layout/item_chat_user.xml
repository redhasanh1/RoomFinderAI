<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:gravity="end">

    <!-- Message Content Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="80dp"
        android:layout_marginEnd="16dp"
        android:gravity="end">

        <!-- Premium User Message Bubble -->
        <FrameLayout
            android:id="@+id/messageBubbleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/user_bubble_modern"
            android:elevation="2dp">

            <TextView
                android:id="@+id/messageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="18dp"
                android:text="Hello, I'm looking for a 2 bedroom apartment"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:lineSpacingExtra="2dp"
                android:fontFamily="sans-serif"
                android:maxWidth="300dp"
                android:textIsSelectable="true" />

        </FrameLayout>

        <!-- Message Metadata -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <!-- Delivery Status Icons -->
            <ImageView
                android:id="@+id/deliveryStatus"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_check"
                android:tint="@color/success"
                android:alpha="0.7"
                android:visibility="gone"
                android:contentDescription="Message delivered" />
            
            <TextView
                android:id="@+id/timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:34 PM"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>

    </LinearLayout>

    <!-- User Avatar (Optional) -->
    <ImageView
        android:id="@+id/userAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="@color/gray_300"
        android:src="@drawable/ic_person"
        android:tint="@color/text_secondary"
        android:padding="8dp"
        android:visibility="gone"
        android:contentDescription="Your avatar" />

</LinearLayout>