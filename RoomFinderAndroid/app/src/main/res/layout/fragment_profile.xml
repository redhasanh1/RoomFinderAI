<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/enhanced_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============ GUEST VIEW ============ -->
            <LinearLayout
                android:id="@+id/guestView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Enhanced Hero Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center"
                    android:background="@drawable/enhanced_gradient_header">

                    <ImageView
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:src="@drawable/ic_home"
                        android:tint="@color/white"
                        android:layout_marginBottom="24dp"
                        android:padding="20dp"
                        android:background="@drawable/enhanced_avatar_background" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome to RoomFinder"
                        android:textSize="32sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:letterSpacing="0.02"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find your perfect room with AI assistance"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:alpha="0.9"
                        android:lineSpacingExtra="4dp"
                        android:fontFamily="sans-serif-light" />

                </LinearLayout>

                <!-- Enhanced Feature Cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="What you can do with RoomFinder"
                        android:textSize="24sp"
                        android:textColor="@color/enhanced_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="24dp"
                        android:letterSpacing="0.01" />

                    <!-- Feature Cards Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/enhanced_surface"
                            app:strokeColor="@color/enhanced_border_light"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="20dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_home"
                                    android:tint="@color/enhanced_primary"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Browse Listings"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:gravity="center"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="10,000+ verified properties"
                                    android:textSize="13sp"
                                    android:textColor="@color/enhanced_text_secondary"
                                    android:gravity="center"
                                    android:lineSpacingExtra="2dp" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/enhanced_surface"
                            app:strokeColor="@color/enhanced_border_light"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="20dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ai_negotiator_icon"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AI Assistant"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:gravity="center"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Smart recommendations"
                                    android:textSize="13sp"
                                    android:textColor="@color/enhanced_text_secondary"
                                    android:gravity="center"
                                    android:lineSpacingExtra="2dp" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/enhanced_surface"
                            app:strokeColor="@color/enhanced_border_light"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="20dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_chat"
                                    android:tint="@color/enhanced_primary"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Chat &amp; Negotiate"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:gravity="center"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Direct messaging"
                                    android:textSize="13sp"
                                    android:textColor="@color/enhanced_text_secondary"
                                    android:gravity="center"
                                    android:lineSpacingExtra="2dp" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/enhanced_surface"
                            app:strokeColor="@color/enhanced_border_light"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="20dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_bookmark"
                                    android:tint="@color/enhanced_primary"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Save Favorites"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:gravity="center"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Bookmark matches"
                                    android:textSize="13sp"
                                    android:textColor="@color/enhanced_text_secondary"
                                    android:gravity="center"
                                    android:lineSpacingExtra="2dp" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>

                <!-- Recent Listings Preview -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recent Listings"
                        android:textSize="22sp"
                        android:textColor="@color/enhanced_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="16dp"
                        android:letterSpacing="0.01" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/guestRecentListingsRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        tools:listitem="@layout/item_listing_horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign up to contact landlords and save favorites"
                        android:textSize="16sp"
                        android:textColor="@color/enhanced_text_secondary"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

                <!-- Enhanced Call to Action -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/signupButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Get Started - Sign Up Free"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/enhanced_button_primary"
                        android:elevation="4dp"
                        android:layout_marginBottom="16dp"
                        android:letterSpacing="0.02" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/loginButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Already have account? Sign In"
                        android:textSize="16sp"
                        android:textColor="@color/enhanced_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/enhanced_card_selector"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/browseAsGuestButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Continue browsing as guest"
                        android:textColor="@color/enhanced_accent"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:padding="16dp"
                        android:layout_gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                </LinearLayout>

            </LinearLayout>

            <!-- ============ USER VIEW ============ -->
            <LinearLayout
                android:id="@+id/userView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Enhanced Profile Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:background="@drawable/enhanced_gradient_header">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/userAvatar"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_person"
                            android:background="@drawable/enhanced_avatar_background"
                            android:padding="16dp"
                            android:tint="@color/enhanced_primary"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="20dp">

                            <TextView
                                android:id="@+id/userName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="John Doe"
                                android:textSize="28sp"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.02"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/userEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="john@example.com"
                                android:textSize="16sp"
                                android:textColor="@color/white"
                                android:alpha="0.9"
                                android:fontFamily="sans-serif-light" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Enhanced Quick Stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/enhanced_stats_pill"
                            android:padding="16dp"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:id="@+id/savedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:textSize="24sp"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Saved"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:alpha="0.9"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/enhanced_stats_pill"
                            android:padding="16dp"
                            android:layout_marginHorizontal="4dp">

                            <TextView
                                android:id="@+id/postedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textSize="24sp"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Posted"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:alpha="0.9"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/enhanced_stats_pill"
                            android:padding="16dp"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:id="@+id/messagesCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5"
                                android:textSize="24sp"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Messages"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:alpha="0.9"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Enhanced Quick Actions Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Actions"
                        android:textSize="22sp"
                        android:textColor="@color/enhanced_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="20dp"
                        android:letterSpacing="0.01" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/myListingsCard"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="@color/enhanced_surface"
                            app:strokeColor="@color/enhanced_border_light"
                            app:strokeWidth="1dp"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="20dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_home"
                                    android:tint="@color/enhanced_primary"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="My Listings"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:gravity="center" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/savedPropertiesCard"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="@color/enhanced_surface"
                            app:strokeColor="@color/enhanced_border_light"
                            app:strokeWidth="1dp"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="20dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_bookmark"
                                    android:tint="@color/enhanced_primary"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Saved"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:gravity="center" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/messagesCard"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="@color/enhanced_surface"
                            app:strokeColor="@color/enhanced_border_light"
                            app:strokeWidth="1dp"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="20dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_chat"
                                    android:tint="@color/enhanced_primary"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Messages"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:gravity="center" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/aiAssistantCard"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="@color/enhanced_surface"
                            app:strokeColor="@color/enhanced_border_light"
                            app:strokeWidth="1dp"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="20dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ai_negotiator_icon"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AI Assistant"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:gravity="center" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/toolsCard"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="@color/enhanced_surface"
                        app:strokeColor="@color/enhanced_border_light"
                        app:strokeWidth="1dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="24dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_computer"
                                android:tint="@color/enhanced_primary"
                                android:layout_marginEnd="20dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tools"
                                    android:textSize="18sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/enhanced_text_primary"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Advanced utilities and settings"
                                    android:textSize="14sp"
                                    android:textColor="@color/enhanced_text_secondary" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_arrow_right"
                                android:tint="@color/enhanced_text_tertiary" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Enhanced Recent Listings -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Recent Listings"
                        android:textSize="22sp"
                        android:textColor="@color/enhanced_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="16dp"
                        android:letterSpacing="0.01" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recentListingsRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        tools:listitem="@layout/item_listing_horizontal" />

                </LinearLayout>

                <!-- Enhanced Account Settings -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="24dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/enhanced_surface"
                    app:strokeColor="@color/enhanced_border_light"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Account"
                            android:layout_margin="24dp"
                            android:textSize="20sp"
                            android:textColor="@color/enhanced_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.01" />

                        <LinearLayout
                            android:id="@+id/settingsItem"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="24dp"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:tint="@color/enhanced_text_secondary"
                                android:src="@drawable/ic_settings" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="20dp"
                                android:text="Settings"
                                android:textSize="16sp"
                                android:textColor="@color/enhanced_text_primary"
                                android:fontFamily="sans-serif"/>
                            
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:tint="@color/enhanced_text_tertiary"
                                android:src="@drawable/ic_arrow_right"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/enhanced_border_light"
                            android:layout_marginHorizontal="24dp" />

                        <LinearLayout
                            android:id="@+id/helpItem"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="24dp"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackgroundBorderless">
                            
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:tint="@color/enhanced_text_secondary"
                                android:src="@drawable/ic_info" />
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="20dp"
                                android:text="Help &amp; Support"
                                android:textSize="16sp"
                                android:textColor="@color/enhanced_text_primary"
                                android:fontFamily="sans-serif"/>
                            
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:tint="@color/enhanced_text_tertiary"
                                android:src="@drawable/ic_arrow_right"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/enhanced_border_light"
                            android:layout_marginHorizontal="24dp" />

                        <LinearLayout
                            android:id="@+id/deleteAccountItem"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="24dp"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackgroundBorderless">
                            
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:tint="@color/error"
                                android:src="@android:drawable/ic_menu_delete" />
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="20dp"
                                android:text="Delete Account"
                                android:textSize="16sp"
                                android:textColor="@color/error"
                                android:fontFamily="sans-serif"/>
                            
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:tint="@color/error"
                                android:src="@drawable/ic_arrow_right"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Enhanced Logout -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/logoutButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="32dp"
                    android:text="Sign Out"
                    android:textSize="16sp"
                    android:textColor="@color/enhanced_text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/enhanced_card_selector" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>