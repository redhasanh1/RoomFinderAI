<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/futuristic_gradient_background"
    android:orientation="vertical">

    <!-- Modern Search Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/ai_chat_card_background"
        android:elevation="8dp"
        android:paddingBottom="16dp">

        <!-- Main Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical">

            <!-- Enhanced Search Input -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:background="@drawable/glassmorphism_search_bar"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:elevation="8dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/accent_cyan"
                    android:alpha="0.9"
                    android:scaleType="centerInside" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/searchInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="Search apartments, houses, condos..."
                    android:textColorHint="#80FFFFFF"
                    android:textColor="@color/white"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:imeOptions="actionSearch" />

                <ImageView
                    android:id="@+id/voiceSearchButton"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_mic"
                    android:tint="@color/accent_cyan"
                    android:alpha="0.7"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp" />

            </LinearLayout>

            <!-- Search Action Button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/searchButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:backgroundTint="@android:color/transparent"
                android:background="@drawable/premium_button_gradient"
                android:src="@drawable/ic_search"
                android:tint="@color/white"
                android:elevation="12dp"
                app:fabSize="normal"
                app:borderWidth="0dp"
                app:rippleColor="#40FFFFFF" />

        </LinearLayout>

        <!-- Quick Filters -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/quickFiltersGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:chipSpacingHorizontal="12dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/quickFilterPrice"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="💰 Price"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="6dp"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/quickFilterLocation"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="📍 Location"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="6dp"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/quickFilterType"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="🏠 Type"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="6dp"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/quickFilterBeds"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="🛏️ Beds"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="6dp"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/quickFilterMore"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="✨ More Filters"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="6dp"
                    app:chipIcon="@drawable/ic_filter"
                    app:chipIconTint="@color/accent_cyan" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- Legacy elements for compatibility -->
            <View
                android:id="@+id/clearSearchButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/searchContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"
                android:orientation="horizontal" />

            <!-- Legacy Active Filters Summary (removed to avoid duplicate ID) -->

            <!-- Search Suggestions - Always Visible -->
            <LinearLayout
                android:id="@+id/searchSuggestionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="16dp"
                android:paddingHorizontal="24dp"
                android:paddingVertical="20dp"
                android:background="@drawable/glassmorphism_card"
                android:elevation="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Popular searches"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:alpha="0.9"
                    android:layout_marginBottom="16dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/searchSuggestionsChips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:chipSpacingHorizontal="12dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/suggestionDowntown"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:text="🏙️ Downtown"
                            android:textSize="13sp"
                            android:background="@drawable/floating_chip_glass"
                            android:elevation="4dp"
                            android:checkable="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/suggestionAffordable"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:text="💸 Under $1200"
                            android:textSize="13sp"
                            android:background="@drawable/floating_chip_glass"
                            android:elevation="4dp"
                            android:checkable="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/suggestion2Bed"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:text="🏠 2 Bedroom"
                            android:textSize="13sp"
                            android:background="@drawable/floating_chip_glass"
                            android:elevation="4dp"
                            android:checkable="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/suggestionPetFriendly"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:text="🐕 Pet Friendly"
                            android:textSize="13sp"
                            android:background="@drawable/floating_chip_glass"
                            android:elevation="4dp"
                            android:checkable="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/suggestionNearby"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:text="📍 Near Me"
                            android:textSize="13sp"
                            android:background="@drawable/floating_chip_glass"
                            android:elevation="4dp"
                            android:checkable="false" />

                    </com.google.android.material.chip.ChipGroup>

                </HorizontalScrollView>

            </LinearLayout>

            <!-- Active Filters Display -->
            <LinearLayout
                android:id="@+id/activeFiltersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎯 Active Filters"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:alpha="0.9" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/clearAllFiltersButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:text="Clear All"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        android:background="@android:color/transparent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        app:cornerRadius="16dp" />

                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/activeFiltersChips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />

                </HorizontalScrollView>

            </LinearLayout>

            <!-- Advanced Filters - Collapsible -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glassmorphism_card">

                    <!-- Filters Header - Always Visible -->
                    <LinearLayout
                        android:id="@+id/filtersHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="20dp"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_filter"
                            android:tint="@color/accent_cyan"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔧 Advanced Filters"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/filterExpandIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_right"
                            android:tint="@color/accent_cyan"
                            android:alpha="0.8" />

                    </LinearLayout>

                    <!-- Filter Content - Organized in Sections -->
                    <LinearLayout
                        android:id="@+id/filtersScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="24dp">

                        <!-- Price Range Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="28dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="16dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_money"
                                    android:tint="@color/accent_cyan"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Price Range"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/priceChipGroup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:singleSelection="true"
                                app:chipSpacingHorizontal="8dp"
                                app:chipSpacingVertical="4dp">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/priceUnder1000"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="Under $1000"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/price1000to1500"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="$1000 - $1500"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/price1500to2000"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="$1500 - $2000"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/priceOver2000"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="Over $2000"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                            </com.google.android.material.chip.ChipGroup>

                        </LinearLayout>

                        <!-- Property Type Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="28dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="16dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_home"
                                    android:tint="@color/accent_cyan"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Property Type"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/propertyTypeChipGroup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:singleSelection="false"
                                app:chipSpacingHorizontal="8dp"
                                app:chipSpacingVertical="4dp">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/typeApartment"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="🏢 Apartment"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/typeHouse"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="🏠 House"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/typeCondo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="🏘️ Condo"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/typeStudio"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="🏠 Studio"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                            </com.google.android.material.chip.ChipGroup>

                        </LinearLayout>

                        <!-- Bedrooms Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="28dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="16dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_bed"
                                    android:tint="@color/accent_cyan"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Bedrooms"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/bedroomsChipGroup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:singleSelection="true"
                                app:chipSpacingHorizontal="8dp">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/bedroom1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="🛏️ 1 Bed"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/bedroom2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="🛏️ 2 Beds"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/bedroom3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="🛏️ 3 Beds"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/bedroom4Plus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="44dp"
                                    android:text="🛏️ 4+ Beds"
                                    android:textSize="14sp"
                                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                            </com.google.android.material.chip.ChipGroup>

                        </LinearLayout>

                        <!-- Apply Filters Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clearFiltersButton"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="8dp"
                            android:text="✨ Apply Filters"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:background="@drawable/premium_button_gradient"
                            android:textColor="@android:color/white"
                            app:cornerRadius="28dp"
                            android:elevation="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Results Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <!-- Results RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />

                <!-- Enhanced Loading State -->
                <LinearLayout
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="48dp"
                    android:visibility="gone">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminate="true"
                        app:indicatorColor="@color/accent_cyan"
                        app:trackColor="#33FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="🔍 Searching properties..."
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:alpha="0.8" />

                </LinearLayout>

                <!-- Enhanced Empty State -->
                <LinearLayout
                    android:id="@+id/emptyLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="48dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/ic_search_empty"
                        android:tint="#60FFFFFF"
                        android:alpha="0.6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="No properties found"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:alpha="0.9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Try adjusting your search criteria or filters"
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        android:alpha="0.7"
                        android:gravity="center" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/clearSearchFiltersButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:text="🔄 Clear All Filters"
                        android:textSize="14sp"
                        android:background="@android:color/transparent"
                        android:textColor="@color/accent_cyan"
                        app:strokeColor="@color/accent_cyan"
                        app:strokeWidth="2dp"
                        app:cornerRadius="24dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Modern Bottom Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/floating_dock_background"
        android:elevation="16dp">

        <!-- Results Summary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp">

            <TextView
                android:id="@+id/resultsCountText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🏠 0 properties found"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:alpha="0.9" />

            <!-- Sort Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sortButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="📊 Sort"
                android:textSize="14sp"
                android:textColor="@color/accent_cyan"
                android:background="@drawable/floating_chip_glass"
                app:cornerRadius="22dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp" />

        </LinearLayout>

        <!-- Hidden Sort Options -->
        <HorizontalScrollView
            android:id="@+id/sortOptionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp"
            android:scrollbars="none"
            android:visibility="gone">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/sortChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:singleSelection="true"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortRelevance"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="⚡ Relevance"
                    android:textSize="13sp"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="4dp"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortPriceLow"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="💰 Price: Low to High"
                    android:textSize="13sp"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="4dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortPriceHigh"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="💎 Price: High to Low"
                    android:textSize="13sp"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="4dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortNewest"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="🆕 Newest First"
                    android:textSize="13sp"
                    android:background="@drawable/floating_chip_glass"
                    android:elevation="4dp" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Legacy elements for compatibility -->
    <View
        android:id="@+id/resultsHeader"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>