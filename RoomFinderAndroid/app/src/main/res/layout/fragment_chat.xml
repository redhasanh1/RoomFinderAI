<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Modern Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="24dp"
                android:elevation="4dp"
                android:layout_marginBottom="40dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connect &amp; Chat"
                    android:textColor="#000000"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose how you want to connect with properties"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- Premium AI Negotiator Chat Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/aiChatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <!-- Custom background with glassmorphism -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ai_chat_card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="28dp"
                        android:gravity="center_vertical">

                        <!-- Content Container -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- AI Negotiator Title -->
                            <TextView
                                android:id="@+id/aiChatTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="AI Negotiator"
                                android:textColor="@color/white"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:shadowColor="#40000000"
                                android:shadowDx="1"
                                android:shadowDy="2"
                                android:shadowRadius="3"
                                android:layout_marginBottom="16dp" />

                            <!-- Description -->
                            <TextView
                                android:id="@+id/aiChatDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Get expert help negotiating rent, lease terms, and property deals with our AI-powered assistant"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:lineSpacingExtra="4dp"
                                android:alpha="0.9"
                                android:fontFamily="sans-serif" />

                        </LinearLayout>

                        <!-- Arrow -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="16dp"
                            android:src="@drawable/ic_arrow_right"
                            android:tint="@color/white"
                            android:contentDescription="Go to AI Negotiator" />

                    </LinearLayout>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Normal Chat Card - Sleek Design -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/normalChatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/enhanced_gradient_header">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="24dp"
                        android:gravity="center_vertical">

                        <!-- Modern Person Icon -->
                        <LinearLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/circle_background"
                            android:backgroundTint="@color/purple_primary"
                            android:layout_marginEnd="20dp"
                            android:gravity="center"
                            android:elevation="2dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_person"
                                android:tint="@color/white"
                                android:contentDescription="Chat with People" />

                        </LinearLayout>

                        <!-- Content -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Direct Messages"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chat directly with property owners and other renters"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:lineSpacingExtra="2dp" />

                        </LinearLayout>

                        <!-- Arrow -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center_vertical"
                            android:src="@drawable/ic_arrow_right"
                            android:tint="@color/white"
                            android:contentDescription="Go to Direct Messages" />

                    </LinearLayout>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom Spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>