<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:gravity="start">

    <!-- AI Avatar -->
    <ImageView
        android:id="@+id/aiAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="@color/purple_primary"
        android:src="@drawable/ai_negotiator_logo"
        android:padding="6dp"
        android:contentDescription="User avatar" />

    <!-- Message Content Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="80dp">

        <!-- Photo Message Bubble -->
        <FrameLayout
            android:id="@+id/messageBubbleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:background="@drawable/chat_bubble_ai_premium"
            android:elevation="4dp"
            android:padding="6dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Photo Container -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp">

                    <!-- Photo ImageView -->
                    <ImageView
                        android:id="@+id/photoImageView"
                        android:layout_width="200dp"
                        android:layout_height="150dp"
                        android:scaleType="centerCrop"
                        android:background="@color/gray_200"
                        android:contentDescription="Received photo"
                        app:cornerRadius="12dp" />

                    <!-- Loading Progress -->
                    <ProgressBar
                        android:id="@+id/photoLoadingProgress"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@color/purple_primary" />

                    <!-- Error Overlay -->
                    <FrameLayout
                        android:id="@+id/photoErrorOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#80000000"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_info"
                            android:tint="@color/white"
                            android:contentDescription="Failed to load image" />

                    </FrameLayout>

                </FrameLayout>

                <!-- Photo Caption (Optional) -->
                <TextView
                    android:id="@+id/photoCaptionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="8dp"
                    android:text="Photo caption here"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp"
                    android:maxWidth="200dp"
                    android:visibility="gone" />

            </LinearLayout>

        </FrameLayout>

        <!-- Message Metadata -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginTop="6dp"
            android:layout_marginStart="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:34 PM"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>