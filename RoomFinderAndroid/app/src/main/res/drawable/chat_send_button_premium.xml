<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Premium Shadow -->
    <item android:top="2dp" android:left="2dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="25dp"
                android:startColor="#40667EEA"
                android:endColor="#00667EEA" />
        </shape>
    </item>
    
    <!-- Main Gradient -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#667EEA"
                android:centerColor="#6B7FEB"
                android:endColor="#764BA2" />
        </shape>
    </item>
    
    <!-- Glass Overlay -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#50FFFFFF"
                android:centerColor="#25FFFFFF"
                android:endColor="#08FFFFFF" />
        </shape>
    </item>
    
    <!-- Subtle Border -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke 
                android:width="1dp" 
                android:color="#40FFFFFF" />
        </shape>
    </item>
    
    <!-- Top Highlight -->
    <item android:bottom="25dp" android:right="8dp" android:top="5dp" android:left="8dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#60FFFFFF"
                android:centerColor="#30FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
    
</layer-list>