<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused State -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Enhanced Glow Effect -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="radial"
                        android:gradientRadius="80dp"
                        android:startColor="#30667EEA"
                        android:centerColor="#15667EEA"
                        android:endColor="#00667EEA" />
                    <corners android:radius="30dp" />
                </shape>
            </item>
            
            <!-- Main Background -->
            <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#FFFFFF"
                        android:centerColor="#FDFDFF"
                        android:endColor="#FAFCFF" />
                    <corners android:radius="26dp" />
                </shape>
            </item>
            
            <!-- Enhanced Glass Effect -->
            <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="45"
                        android:startColor="#30FFFFFF"
                        android:centerColor="#20FFFFFF"
                        android:endColor="#10FFFFFF" />
                    <corners android:radius="26dp" />
                </shape>
            </item>
            
            <!-- Focused Border -->
            <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                    <corners android:radius="26dp" />
                    <stroke 
                        android:width="2dp" 
                        android:color="#60667EEA" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Default State -->
    <item>
        <layer-list>
            <!-- Outer Shadow -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="radial"
                        android:gradientRadius="60dp"
                        android:startColor="#15000000"
                        android:endColor="#00000000" />
                    <corners android:radius="28dp" />
                </shape>
            </item>
            
            <!-- Main Background -->
            <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#FEFEFE"
                        android:centerColor="#FBFCFF"
                        android:endColor="#F8FAFF" />
                    <corners android:radius="26dp" />
                </shape>
            </item>
            
            <!-- Glass Effect -->
            <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="45"
                        android:startColor="#20FFFFFF"
                        android:centerColor="#10FFFFFF"
                        android:endColor="#05FFFFFF" />
                    <corners android:radius="26dp" />
                </shape>
            </item>
            
            <!-- Premium Border -->
            <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                    <corners android:radius="26dp" />
                    <stroke 
                        android:width="1.5dp" 
                        android:color="#30667EEA" />
                </shape>
            </item>
        </layer-list>
    </item>
    
</selector>