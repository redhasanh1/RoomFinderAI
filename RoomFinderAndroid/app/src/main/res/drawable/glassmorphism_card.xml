<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item android:top="4dp" android:left="4dp" android:bottom="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="200dp"
                android:startColor="#20667EEA"
                android:endColor="#00667EEA" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Main shadow -->
    <item android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#25000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Glass surface -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#35FFFFFF"
                android:centerColor="#25FFFFFF"
                android:endColor="#15FFFFFF" />
            <corners android:radius="20dp" />
            <stroke 
                android:width="1dp" 
                android:color="#40FFFFFF" />
        </shape>
    </item>
    <!-- Light reflection -->
    <item android:top="2dp" android:left="2dp" android:bottom="30dp" android:right="30dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>