<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Shadow Layer -->
    <item android:left="2dp" android:right="2dp" android:top="4dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#15000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Main Gradient Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#F0667eea"
                android:centerColor="#F0764ba2"
                android:endColor="#F0667eea" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Glassmorphism Overlay -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#20FFFFFF" />
            <corners android:radius="19dp" />
        </shape>
    </item>
    
    <!-- Top Highlight -->
    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="70%">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    
    <!-- Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke 
                android:width="1dp" 
                android:color="#30FFFFFF" />
            <corners android:radius="20dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    
</layer-list>