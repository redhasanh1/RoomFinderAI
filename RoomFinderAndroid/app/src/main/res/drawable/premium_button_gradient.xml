<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item android:top="3dp" android:left="3dp" android:bottom="3dp" android:right="3dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:startColor="#4000FFCC"
                android:endColor="#0000FFCC" />
        </shape>
    </item>
    <!-- Shadow -->
    <item android:top="2dp" android:left="2dp">
        <shape android:shape="oval">
            <solid android:color="#30000000" />
        </shape>
    </item>
    <!-- Main gradient -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#00FFCC"
                android:centerColor="#00E6B8"
                android:endColor="#00B4DB" />
            <stroke 
                android:width="2dp" 
                android:color="#80FFFFFF" />
        </shape>
    </item>
    <!-- Inner shine -->
    <item android:top="4dp" android:left="4dp" android:bottom="20dp" android:right="20dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="15dp"
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>