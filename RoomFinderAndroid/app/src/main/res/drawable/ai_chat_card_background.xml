<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Premium Outer Glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#30667EEA"
                android:centerColor="#20764BA2" 
                android:endColor="#00667EEA" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    
    <!-- Main Shadow Layer -->
    <item android:top="3dp" android:left="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#40000000"
                android:endColor="#20000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Glass Background Base -->
    <item android:top="1dp" android:left="1dp" android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#667EEA"
                android:centerColor="#6B7FEB"
                android:endColor="#764BA2" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Glass Overlay Effect -->
    <item android:top="1dp" android:left="1dp" android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#40FFFFFF"
                android:centerColor="#25FFFFFF"
                android:endColor="#10FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Premium Border -->
    <item android:top="1dp" android:left="1dp" android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="20dp" />
            <stroke 
                android:width="1.5dp" 
                android:color="#60FFFFFF" />
        </shape>
    </item>
    
    <!-- Light Reflection (Top-Left) -->
    <item android:top="2dp" android:left="2dp" android:bottom="40dp" android:right="40dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#50FFFFFF"
                android:centerColor="#20FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    
    <!-- Subtle Inner Shadow -->
    <item android:top="3dp" android:left="3dp" android:bottom="5dp" android:right="5dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="225"
                android:startColor="#00000000"
                android:centerColor="#00000000"
                android:endColor="#15000000" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    
</layer-list>