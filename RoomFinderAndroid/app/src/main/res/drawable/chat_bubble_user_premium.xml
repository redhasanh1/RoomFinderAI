<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Premium Shadow -->
    <item android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#40000000"
                android:endColor="#15000000" />
            <corners 
                android:topLeftRadius="20dp"
                android:topRightRadius="20dp"
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="6dp" />
        </shape>
    </item>
    
    <!-- Main Gradient Background -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#667EEA"
                android:centerColor="#6B7FEB"
                android:endColor="#764BA2" />
            <corners 
                android:topLeftRadius="20dp"
                android:topRightRadius="20dp"
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="6dp" />
        </shape>
    </item>
    
    <!-- Glass Overlay Effect -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#40FFFFFF"
                android:centerColor="#20FFFFFF"
                android:endColor="#08FFFFFF" />
            <corners 
                android:topLeftRadius="20dp"
                android:topRightRadius="20dp"
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="6dp" />
        </shape>
    </item>
    
    <!-- Subtle Border -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners 
                android:topLeftRadius="20dp"
                android:topRightRadius="20dp"
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="6dp" />
            <stroke 
                android:width="1dp" 
                android:color="#30FFFFFF" />
        </shape>
    </item>
    
    <!-- Top Light Reflection -->
    <item android:bottom="15dp" android:right="5dp" android:top="3dp" android:left="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#50FFFFFF"
                android:centerColor="#20FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners 
                android:topLeftRadius="18dp"
                android:topRightRadius="18dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
    
</layer-list>