<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Outer Shadow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="60dp"
                android:startColor="#15000000"
                android:endColor="#00000000" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    
    <!-- Main Background -->
    <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FAF9FF"
                android:centerColor="#F8F7FF"
                android:endColor="#F5F3FF" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    
    <!-- Glass Effect -->
    <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#20FFFFFF"
                android:centerColor="#10FFFFFF"
                android:endColor="#05FFFFFF" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    
    <!-- Premium Border -->
    <item android:top="1dp" android:left="1dp" android:bottom="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="26dp" />
            <stroke 
                android:width="1.5dp" 
                android:color="#30667EEA" />
        </shape>
    </item>
    
</layer-list>